    //             if($(this).attr("aria-expanded") == "true") {
    //                 $(this).trigger('click');
    //             }
    //         });
    //     }
    // });

 
        $(".d-o-header__dropdown-lvl-1").on("keydown", function(e) {
            if (e.key === "Escape") { 
                e.preventDefault(); 
                $(`.${objectJS}.d-js-header__toggle-carousel`).each(function(){
                    if($(this).attr("aria-expanded") == "true") {
                        $(this).trigger('click');
                    }
                });                 
            }
    });


    
    // Evento para cerrar los dropdowns al hacer clic fuera de ellos
    $(document).click(function () {
        $(`.${objectJS}`).each(function () {

        // Verifica si el preheader tiene la clase "new" y si la resolución no es móvil
        const isMobile = exceedsMaximumResolution(1264);
        const isNewPreheader = $(this).parents('.d-c-preheader').hasClass('d-t-preheader--new');
        if (isNewPreheader && !isMobile) {
            return;  
        }       
            if ($(this).attr("aria-expanded") == "true") {
                if($(this).parents('.d-c-preheader').length > 0 && !exceedsMaximumResolution(1264)) {
                    addDataPreHeader();
                }
              
                    isClicking = false;
             
                let content = $(this).parents(`.${object}`).find(`.${objectJS}__content`);
                content.slideUp(300);
                content.closest(".has-dropdown-btn").removeClass('fondo-white-preheaderLi'); 
                $(this).attr("aria-expanded", "false");
                $(this).removeClass(`${window.prefixClass.js}--active`);
                
                if($(this).parents(".d-c-preheader").length > 0){
                    $(this).closest(".has-dropdown-btn").removeClass('fondo-white-preheaderLi');
                $(this).parent(".d-o-dropdown").find(".d-t-dropdown__btn").removeClass(" d-t-btn-preheader--active");                   
                $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').addClass('d-c-preheader-gray-line');
                $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').removeClass('d-c-preheader-red-line');
                $(this).parent(".d-o-dropdown").removeClass('highlight');
                }
                
            }
           
        });
    });

    // Evita que el clic dentro del dropdown lo cierre
    $(`.${object}`).click(function (e) {
        e.stopPropagation();
    });

    // Evita que el enter dentro del dropdown lo cierre
    $(`.${object}`).on('keydown', function(e) {
        e.stopPropagation();
    });


//FUNCIONES DEL PREHEADER

if (!$('body').hasClass('has-edit-mode-menu')){
    //1.Funciones para abrir el preheader con hover o tab
    let hoverTimeout;
    let closeTimeout;
    let keyboardOpened = false;

    $(document).on('keydown', function(e) {
        if (e.key === 'Tab') {
            keyboardOpened = true;

        }
    });
    
    $(document).on('keyup', function(e) {
        if (e.key === 'Tab') {
            keyboardOpened = false;
        }
    });


// 1.1.Manejar el evento mouseenter y el evento keyboard aca agregamos animacion de apertura


if (exceedsMaximumResolution(1264)) {
    let mouseOverDropdown = false;   
