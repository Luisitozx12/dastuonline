$(window).scroll(function() {
    var container = $('.d-c-preheader');
    var containerTop = container.offset().top; // La posición del contenedor desde la parte superior de la ventana
    var windowScrollTop = $(window).scrollTop(); // Posición actual del scroll

    // Verificar si el contenedor ha comenzado a moverse hacia arriba (1px o más)
    if (windowScrollTop > containerTop) {
        //console.log("contenedor ya no visible");
       

        // Si el contenedor ha comenzado a moverse, cerrar el menú desplegable
        if (!keyboardOpened) {
            if (exceedsMaximumResolution(1264)) {
                $('.d-c-preheader').addClass("blocknavPreheader");
                const content = $('.d-t-dropdown__content');

                // Eliminar cualquier animación o clase relacionada con el despliegue
                content.stop(true, true); // Detener cualquier animación en curso

                // Cerrar el menú de inmediato
                dropdownOpen = false;
                content.slideUp(200); // Animación de cierre rápida sin retraso
                content.removeClass("d-t-dropdown__content-animation"); // Eliminar animación
                $('.d-t-dropdown__btn').attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
            }
        }
    }

    else{

        $('.d-c-preheader').removeClass("blocknavPreheader");

    }
});




