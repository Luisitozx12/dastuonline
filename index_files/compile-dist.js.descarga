function preheader () {
    function initComponent () {

       
     


    //agregamos funciones para redirigir focus en mobile cuando algun dropdpwn este abierto
    var $buttonCarruselItems = $(".item-focuseable");
    var $dropdownPreheader= $(".d-t-dropdown__btn-preheader");
    var $dropdownItems = $(".d-t-dropdown__item");
    const $brandMenu = $('.d-o-header__brand-menu');
    

    function handleButtonFocus(){
        // Escuchar el evento keydown para manejar Tab y Shift + Tab
        $buttonCarruselItems.on('keydown', function(e) {
            var index = $buttonCarruselItems.index(this); // Obtener el índice del botón actual
            //console.log("key down en item", index);
   
            // Detectar si es una tecla Tab
            if (e.keyCode === 9) {
                var $openDropdown = $(".d-t-dropdown__btn[aria-expanded='true']");
                // Si estamos en el último item y estamos avanzando (Tab sin Shift)
                if (index === $buttonCarruselItems.length - 1 && !e.shiftKey) {
                  
                    //var $openDropdown = $(".d-t-dropdown__btn[aria-expanded='true']");
                   
                    // Si hay un dropdown abierto
                    if ($openDropdown.length > 0) {
                        var $dropdownContent = $openDropdown.closest('.d-t-dropdown').find('.d-t-dropdown__content');
                        var $firstDropdownItem = $dropdownContent.find(".d-t-dropdown__item").first();
                        $firstDropdownItem.focus();
                        e.preventDefault();  // Prevenir la acción predeterminada de Tab

                        
                    } else {
                        // Si no hay un dropdown abierto, mover al primer ítem de dropdown globalmente
                        $dropdownItems.first().focus();
                        e.preventDefault();  // Prevenir la acción predeterminada de Tab
                    }
                } 
               
                
                else if (index === 0 && e.shiftKey) {
                    // Si estamos en el primer ítem y retrocedemos (Shift + Tab)
                    //console.log("estoy en el primer item del carrusel y retrocediendo");
                    var $dropdownItemsFirst = $dropdownItems.first();
                    //$dropdownItemsFirst.focus();
                    //e.preventDefault();  // Prevenir la acción predeterminada de Tab
                }
                // Si no estamos en el primer o último ítem, solo movemos el foco entre los ítems
                else if (e.shiftKey) {
                    // Si estamos retrocediendo (Shift + Tab)
                    var prevItem = $buttonCarruselItems.eq(index - 1);
                    prevItem.focus();
                    e.preventDefault();  // Prevenir la acción predeterminada de Tab
                } else {
                    // Si estamos avanzando (Tab sin Shift)
                    var nextItem = $buttonCarruselItems.eq(index + 1);
                    nextItem.focus();
                    e.preventDefault();  // Prevenir la acción predeterminada de Tab
                }
            }
        });
        $dropdownItems.on('keydown', function(e) {
            var index = $buttonCarruselItems.index(this); // Obtener el índice del botón actual
            //console.log("key down en item", index);
   
            // Detectar si es una tecla Tab
            if (e.keyCode === 9) {
                var $openDropdown = $(".d-t-dropdown__btn[aria-expanded='true']");
                // Si estamos en el último item y estamos avanzando (Tab sin Shift)
                if (index === $dropdownItems.length - 1 && !e.shiftKey) {

                    console.log("ultimo item del drop");
                    //e.preventDefault(); // Prevenimos el comportamiento predeterminado de Tab
                    $brandMenu.focus(); 
                  
                  
                } 
            }
        })      
    }

    function handleDropFocus() {
        // Seleccionamos solo los ítems del dropdown que está abierto actualmente
        var $openDropdown = $(".d-t-dropdown__btn[aria-expanded='true']");
    
        // Aseguramos que el dropdown esté abierto
        if ($openDropdown.length > 0) {
            var $dropdownContent = $openDropdown.closest('.d-t-dropdown').find('.d-t-dropdown__content');
            var $dropdownItems = $dropdownContent.find('.d-t-dropdown__item'); // Seleccionamos solo los ítems del dropdown abierto
            
            var isLastItem = false;  // Variable para identificar si estamos en el último ítem
            
            // Escuchar el evento focus en lugar de keydown para detectar el foco
            $dropdownItems.on('focus', function() {
                var index = $dropdownItems.index(this);  // Obtener el índice del ítem con el foco
                console.log("Foco actual en el item: ", this);  // Ver qué ítem tiene el foco
                console.log("Índice del ítem actual: ", index);
    
                // Si estamos en el último item y no estamos retrocediendo (Shift + Tab)
                if (index === $dropdownItems.length - 1) {
                    isLastItem = true;  // Marcar que estamos en el último ítem
                } else {
                    isLastItem = false;  // Resetear si no estamos en el último ítem
                }
            });
    
            // Detectar la tecla Tab cuando estemos en el último ítem
            $(document).on('keydown', function(e) {
                if (e.keyCode === 9 && isLastItem && !e.shiftKey) {
                    // Prevenir el comportamiento predeterminado de Tab
                    console.log("Último ítem del dropdown, moviendo foco a #brandMenu");
                    e.preventDefault();  // Prevenir el comportamiento predeterminado de Tab
    
                    // Mover el foco directamente a #brandMenu
                    $brandMenu.focus();
                    isLastItem = false;  // Resetear el estado después de mover el foco
                }
                // Detectar cuando se presiona Shift + Tab estando en #brandMenu
            if (e.keyCode === 9 && e.shiftKey && document.activeElement === $brandMenu[0]) {
                console.log("Shift + Tab presionado en #brandMenu, moviendo foco al último ítem del dropdown");
                e.preventDefault();  // Prevenir el comportamiento predeterminado de Tab
                var $lastItem = $dropdownItems.last(); // Obtener el último ítem del dropdown
                $lastItem.focus();  // Mover el foco al último ítem del dropdown
                isLastItem = true;  // Marcar que estamos en el último ítem
            }
            });
        }
    }

//handleDropFocus();

    function handleDropdownFocus() {
        // Escuchar el evento keydown en todos los items del dropdown
        $dropdownItems.on('keydown', function(e) {
            // Verificar si se presiona Shift + Tab (e.shiftKey para Shift)
            if (e.keyCode === 9 && e.shiftKey) {
                // Encontrar el dropdown que está abierto
                var $openDropdown = $(".d-t-dropdown__btn[aria-expanded='true']");
    
                if ($openDropdown.length > 0) { // Si hay un dropdown abierto
                    var $dropdownContent = $openDropdown.closest('.d-t-dropdown').find('.d-t-dropdown__content');
                    var $firstDropdownItem = $dropdownContent.find(".d-t-dropdown__item").first(); // Primer item del dropdown
                    
                    // Si el foco está en el segundo item del carrusel, movemos al primero
                    if (document.activeElement === $buttonCarruselItems.eq(1)[0]) {
                        //console.log("Focus en el segundo item, moviéndolo al primer item");
                        $buttonCarruselItems.first()[0].focus();
                        e.preventDefault();  // Prevenir la acción predeterminada de Tab
                    }
    
                    // Si el foco está en el primer item del dropdown, lo movemos al último botón del carrusel
                    if ($firstDropdownItem.length > 0 && document.activeElement === $firstDropdownItem[0]) {
                        //console.log("Focus hacia el último button del carrusel");
                        var $lastCarruselItem = $buttonCarruselItems.last();
                        if ($lastCarruselItem.length > 0) {
                            $lastCarruselItem[0].focus(); // Aquí es seguro acceder a [0] porque ya hemos comprobado que existe
                            e.preventDefault();  // Prevenir la acción predeterminada de Tab
                        }
                    }
                }
            }
        });
    }

    function isMobile() {
        return window.innerWidth <= 1264;  // Ajusta según tu necesidad
    }

    function handleDropdownKeydown() {
        if (isMobile()) {

            //console.log("estamos en mobile");
            // Si estamos en móvil, escuchamos los keydown en los items del dropdown
            $dropdownPreheader.on('keyup', function(e) {

                //console.log("escuchando el enter");
                var $currentDropdownItem = $(this);
                var isDropdownOpen = $currentDropdownItem.attr('aria-expanded') === 'true';

                // Si el dropdown está abierto, manejamos el foco
                setTimeout(function() {
                    if (isDropdownOpen) {
                        //console.log("dropdown abierto");
                        // Llamamos a handleButtonFocus y handleDropdownFocus solo si hay un dropdown abierto
                        handleButtonFocus(); 
                        handleDropdownFocus();
                        handleDropFocus()
                    } else {
                        //console.log("dropdown cerrado");
                    }
                }, 100);

            });
        }
    }

    function anyDropdownOpen() {
        if (isMobile()) {

            //console.log("estamos en mobile");
            // Si estamos en móvil, escuchamos los keydown en los items del dropdown
            $(".button-carrusel").on('click keydown', function(e) {

                //console.log("escuchando el focus en cualquier dropdpwon");
                var isAnyDropdownOpen = $(".d-t-dropdown__btn").filter(function() {
                    return $(this).attr('aria-expanded') === 'true';
                }).length > 0;

                if (isAnyDropdownOpen) {
                    //console.log("Al menos un dropdown está abierto");                    
                    //$(".d-t-dropdown__item").attr("tabindex", "-1");
                  
                }
                else {
                    // Si ninguno de los dropdowns está abierto, poner tabindex="0" a todos los items
                    //console.log("Ningún dropdown está abierto");                    
                    //$(".d-t-dropdown__item").attr("tabindex", "1");
                    //$(".button-carrusel").attr("tabindex", "0");

                    $(".d-o-header__search").removeClass("hiddeTanHeadder");
                    $(".d-o-header__desktop-menu").removeClass("hiddeTanHeadder");
                    $(".d-o-header__collapse-footer").removeClass("hiddeTanHeadder");
                }

            });
        }
    }



    function handleResizePreheader() {
        if (!isMobile()) {
            $(".d-o-header__search").removeClass("hiddeTanHeadder");
            $(".d-o-header__desktop-menu").removeClass("hiddeTanHeadder");
            $(".d-o-header__collapse-footer").removeClass("hiddeTanHeadder");
        } 
      }


      // Llama la función al cargar la página
      handleResizePreheader();
  
  // Escucha el evento de resize para cuando el usuario cambie el tamaño de la ventana
  $(window).resize(function() {
    handleResizePreheader();
  });


  function adjustRoles() {
    var ulElement = $('#d-js-preheader-btn-group');
    var listItems = $('.d-c-preheader-item');

    if (isMobile()) {
        // Para dispositivos móviles: role "tablist" en el ul, sin role en los li
        ulElement.attr('role', 'tablist');
        listItems.removeAttr('role');
    } else {
        // Para dispositivos de escritorio: role "menubar" en el ul y "menuitem" en los li
        ulElement.attr('role', 'menubar');
        listItems.attr('role', 'menuitem');
    }
}

// Llamar la función al cargar la página y al redimensionar la ventana
adjustRoles();

$(window).resize(function() {
    adjustRoles();
});


    let usingTab = false;

    // Detectar si el usuario está usando Tab para navegar
    $(document).on("keydown", function(e) {
        if (e.key === "Tab") {
            usingTab = true;
        }
    });
    
    // Resetea la variable si el usuario deja de usar Tab
    $(document).on("mousedown", function() {
        usingTab = false;
    });
    
    if (isMobile()) {
        $buttonCarruselItems.on("focus", function() {
            if (usingTab) { // Solo si está navegando con Tab
                // Obtener el índice del botón que tiene el foco
                var index = $buttonCarruselItems.index(this);   
                // Si el foco está en el último ítem del carrusel
                if (index === $buttonCarruselItems.length - 1) {
                    // Cambiar el tabindex de los ítems del dropdown a 1
                    $dropdownItems.attr("tabindex", "1");
                } else {
                    // Si no está en el último ítem, cambiar el tabindex de los ítems del dropdown a -1
                    $dropdownItems.attr("tabindex", "-1");
                }
            }
        });
    }

    var scrollPosition = $(window).scrollTop();
    $(window).scrollTop(scrollPosition);
    



    handleDropdownKeydown(); 
    anyDropdownOpen();

 


        $('.d-t-dropdown__content').on('click', function(event) {
            event.stopPropagation();
        });
     

// Seleccionamos el div con las clases especificadas
        //funcion para calcular el ancho de las li del preheader y mantener su tamaño al hacer resize        
        function calculateItemWidths() {
            const $items = $('.d-c-preheader-item'); 
            $items.each(function() {
                const itemWidth = $(this).outerWidth(true); 
                $(this).data('calculated-width', itemWidth);
            });
        }
        
        function applyItemWidths() {
            const $items = $('.d-c-preheader-item');
            $items.each(function() {
                const calculatedWidth = $(this).data('calculated-width'); 
                if (calculatedWidth) {
                    $(this).css('width', calculatedWidth); 
                }
            });
        }

        $(window).on('resize', function() {
            clearTimeout(this.resizeTimeout);
            this.resizeTimeout = setTimeout(function() {
                calculateItemWidths();
                applyItemWidths();
            }, 150); 
        });


    
       
        
 // Maneja el clic en el botón del dropdown      
    const $tabs = $('.d-t-preheader--new .d-c-preheader-item:not(.item-side)');
    const $dropdownBtn = $('.d-t-preheader--new .d-t-dropdown__btn-preheader');
    const $tabContainer = $('.d-t-preheader--new #d-js-preheader-btn-group');
    const $tabHighlighter = $('.d-t-preheader--new .d-c-preheader-line');
   

    // Función para manejar el clic en las pestañas y dropdowns
    const handleTabClick = function(e) {
        e.stopPropagation(); // Prevenir la burbuja del evento
    
        let $clickedTab = $(this).hasClass('d-t-dropdown__btn-preheader')
            ? $(this).closest('.d-c-preheader-item')
            : $(this);

           
        // Verificar que la pestaña clicada no tenga la clase .item-side
        if ($clickedTab.hasClass('item-side')) return;    
        const item = $tabs.index($clickedTab); // Obtener el índice de la pestaña   
        if (item === -1) return; // Si no se encontró la pestaña, salir
        if (item === 0 || item === 1) {

            // Cerrar todos los dropdowns cuando le doy click a una tab
            let $allDrops = $(".d-t-dropdown__btn");
            // Cierra todos los otros dropdowns

            $(".d-o-header__search").removeClass("hiddeTanHeadder");
            $(".d-o-header__desktop-menu").removeClass("hiddeTanHeadder");
            $(".d-o-header__collapse-footer").removeClass("hiddeTanHeadder");


            $allDrops.each(function () {
                let $otherDropdown = $(this);
                if ($otherDropdown.attr("aria-expanded") === "true") {
                    let otherContent = $otherDropdown.siblings(".d-t-dropdown__content");
                    otherContent.stop(true, true).slideUp(100).removeClass('expand').addClass('rebounce');
                    $otherDropdown.attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
                }
            });

        }

        
    
        if (! exceedsMaximumResolution(1264)){

    // Remover la clase 'active' de todas las pestañas
        $tabs.removeClass('d-t-btn-preheader--active');
        $tabs.find('button').removeClass('bold');
        $tabs.find('button').addClass('light');
        $tabs.find('.d-c-line').removeClass('d-c-preheader-line');
        
        // Agregar la clase 'active' a la pestaña clicada
        $clickedTab.addClass('d-t-btn-preheader--active');
        $clickedTab.find('button').removeClass('light');
        $clickedTab.find('button').addClass('bold'); 
        $tabs.find('.d-c-line').addClass('d-c-preheader-line');

        }


        $(window).on('resize', function() {
            // Verifica si el tamaño de la ventana es de escritorio (puedes ajustar el valor)
            if ($(window).width() >= 1024) { // Ajusta el valor de 1024px según sea necesario
                // Recorre todos los elementos con la clase 'd-c-preheader-item'
                $('.d-c-preheader-item').each(function() {
                    var $item = $(this);
                    // Verifica que no tenga la clase 'item-side'
                    if (!$item.hasClass('item-side')) {

                        $item.find(".button-carrusel").removeClass("light"); 
                        // Verifica si tiene la clase 'd-t-btn-preheader--active'
                        if ($item.hasClass('d-t-btn-preheader--active')) {
                            // Elimina la clase 'd-t-btn-preheader--active'
                            $item.removeClass('d-t-btn-preheader--active');
                            $item.find(".button-carrusel").removeClass("bold");                                                      
                            $item.find(".button-carrusel").blur();
                        }
                       
                    }
                });
            }
        });
        
    
        // Calcular la posición acumulada de todas las pestañas anteriores
        let positionTab = 0;
        $tabs.slice(0, item).each(function() {
            positionTab += $(this).outerWidth(true); // Sumar el ancho de cada pestaña anterior
        });
    
        const containerPosition = $tabContainer.offset().left - 16; // Ajusta según sea necesario

    
        // Calcular la posición y el ancho del resaltador
        const highlightPosition = positionTab + containerPosition; // Ajustar para el contenedor
        const newHighlightWidth = $clickedTab.outerWidth(true); // Obtener el ancho de la pestaña clicada    
        // Usar setTimeout para asegurar que se aplique el estilo después del DOM
        setTimeout(() => {
            $tabHighlighter.css({
                width: newHighlightWidth, // Cambiar el ancho del resaltador
                transform: `translateX(${highlightPosition}px)`, // Mover el resaltador
                opacity: 1, // el resaltador sea visible
                left: 1,
            });
        }, 0);
    };
    
    // Escuchar el clic en los botones de dropdown y las pestañas
    if (!$('body').hasClass('has-edit-mode-menu')){
        $dropdownBtn.on('click', handleTabClick);

    }
   
    $tabs.on('click', handleTabClick);

    $(window).on('resize', function() {
        const activeTab = $tabs.filter('.d-t-btn-preheader--active');
        if (activeTab.length > 0) {
            if (!$('body').hasClass('has-edit-mode-menu')){
                // Simulamos un evento de clic en la pestaña activa
            handleTabClick.call(activeTab[0], $.Event('click'));

            }
            
        }
    });
   
 
    function heightMenusPreheader($dropdown) {
        if (exceedsMaximumResolution(1264)) {
            const $contentContainer = $dropdown.find('.d-t-dropdown__container-box'); // Contenedores internos
            
            // Verificar si .d-t-dropdown__container-box está presente
            if ($contentContainer.length > 0) {
                // Agregar la clase d-block para poder calcular la altura
                $contentContainer.addClass('d-block');
    
                let maxHeight = 0; // Variable para almacenar la altura máxima
    
                // Iterar sobre cada contenedor para encontrar el que tenga más elementos
                $contentContainer.each(function() {
                    const itemCount = $(this).find('.d-t-dropdown__item').length; // Contar los items
                    const heightValue = $(this).outerHeight(true); // Calcular altura ajustada
    
                    // Actualizar maxHeight si este contenedor tiene más elementos
                    if (itemCount > 0 && heightValue > maxHeight) {
                        maxHeight = heightValue + 32 + 25; // Guardar la altura máxima ajustada
                    }
                });
    
                // Eliminar la clase d-block después de calcular
                $contentContainer.removeClass('d-block');    
                // Asignar la altura calculada al contenido
                $dropdown.css('--menuPreheader-height', maxHeight + 'px'); // Asignar la variable CSS
            }
        }
    }
    
    
        // Llama a la función al abrir el dropdown
        $('.d-t-dropdown__btn').on('click keydown', function() {
                const $dropdown = $(this).siblings('.d-t-dropdown__content'); // Selecciona el dropdown correspondiente
                heightMenusPreheader($dropdown); // Llama a la función con el dropdown específico
           
        });
       

     //agregamos clase container dependiendo de la resolución del componente   
        if (exceedsMaximumResolution(767)) {
        $(".d-c-preheader__container").addClass("container");
        $(".d-c-preheader-btn-group_container").removeClass("container");

    } else {
        $(".d-c-preheader__container").removeClass("container");
        $(".d-c-preheader-btn-group_container").addClass("container");
    }
 
        function cubicBezier(p0, p1, p2, p3, t) {
            // Calcula el valor de Bezier en el tiempo t para los puntos de control dados
            const u = 1 - t;
            const tt = t * t;
            const uu = u * u;
            const uuu = uu * u;
            const ttt = tt * t;
            
            const p = uuu * p0; // (1-t)^3 * p0
            const p1s = 3 * uu * t * p1; // 3*(1-t)^2 * t * p1
            const p2s = 3 * u * tt * p2; // 3*(1-t) * t^2 * p2
            const p3s = ttt * p3; // t^3 * p3
            
            return p + p1s + p2s + p3s; // Sumamos los puntos
        }
        
        $.easing.customEase = function (x, t, b, c, d) {
            // Parametros: x = tiempo actual, t = tiempo transcurrido, b = valor inicial, c = cambio de valor, d = duración
            const p0 = 0; // Inicio (x=0, y=0)
            const p1 = 0.47; // Primer punto de control (x=0.47, y=0)
            const p2 = 0.23; // Segundo punto de control (x=0.23, y=1)
            const p3 = 1; // Fin (x=1, y=1)
            
            let progress = t / d; // Normaliza el tiempo actual
            
            let bezierValue = cubicBezier(p0, p1, p2, p3, progress); // Calcula el valor Bezier
            return b + (c * bezierValue); // Calcula el valor final de la animación
        };

        
        if (! exceedsMaximumResolution(1264)) {
            $('.d-c-preheader-red-line').addClass('show');
            
        } else {
            $('.d-c-preheader-red-line').removeClass('show');
        }

         //agregamos estilos a tab seleccionada
        $('#d-js-preheader-btn-group .item').on('click', function(event) {
            adjustBorders();
        });

        //agregamos estilos a tab-dropdown seleccionada
        $('#d-js-preheader-btn-group .d-t-dropdown__btn').on('click', function(event) {
            adjustBorders();
        });

        
       //ahora calculamos el desplazamiento del carrusel 
       const $container = $('#d-js-preheader-btn-group');
       const $scrollLeft = $('#scroll-left');
       const $scrollRight = $('#scroll-right');

       //let currentIndex = 0; // Empezamos con el índice en 0 (primer ítem)
       let scrollPositions = [];
       let lastScrollAmount = 0;
       let scrollHistory = [];  // Array para almacenar los valores de scrollLeft


  
       function getItemWidthAtIndex(index) {
        if ($container.length > 0) {
            const $items = $container.find('.d-c-preheader-item');
            if ($items.length > index) {
                // Forzar reflujo utilizando offsetWidth (esto fuerza la actualización del layout)
                const forcedReflow = $items.eq(index)[0].offsetWidth;  // Forzamos reflujo
                //console.log(`Reflujo forzado para el ítem ${index}:`, forcedReflow);
            
                // Obtener el ancho del ítem con márgenes
                const itemWidth = $items.eq(index).outerWidth(true);
                //console.log(`Item ${index} width (actualizado): `, itemWidth);  // Verificamos el tamaño del ítem
                return itemWidth;
            }
        }
        return 0; 
       }
  
       let currentIndex = 0;  // Asegúrate de que esta variable no se resetee a cero accidentalmente


       let itemPositions = []; // Array para almacenar las posiciones de los items al hacer clic hacia la derecha



