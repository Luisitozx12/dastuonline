    function changeHTML() {
    if (exceedsMaximumResolution(1264)) {
        $('.d-o-header__dropdown-lvl-2-container').css('min-width', '1136px');
        if (!$('.d-c-header').hasClass('d-t-header--new')) {
            $('.d-o-header__desktop-buttons').prepend($('.d-o-header__mobile-buttons-login'));
            $('.d-o-header__desktop-buttons').prepend($('.d-o-header__collapse-footer-button'));
            $('.d-o-header__desktop-buttons').append($('#d-js-search__toggle'));
        }
        $('body').removeClass('not-scroll');

         $('.d-c-preheader__accessibility').remove();

        const $desktopWrapper = $('<div class="d-c-preheader__accessibility"></div>');
        const desktopPanel = document.createElement('dav-accessibility-panel');
        desktopPanel.setAttribute('panel-title', 'Panel de accesibilidad');
        desktopPanel.setAttribute('title-icon', 'accessibility');
        $desktopWrapper.append(desktopPanel);

        $('.d-c-preheader__container').append($desktopWrapper);
    } else {
        $('.d-o-header__dropdown-lvl-2-container').css('min-width', 'unset');

        // mobile: recrear el panel limpio correctamente
        // const $target = $('.d-o-header__collapse-header-right');
        $('.d-c-preheader__accessibility').remove(); // eliminar el actual

         const $mobileWrapper = $('<div class="d-c-preheader__accessibility"></div>');
        const mobilePanel = document.createElement('dav-accessibility-panel');
        mobilePanel.setAttribute('panel-title', 'Panel de accesibilidad');
        mobilePanel.setAttribute('title-icon', 'accessibility');
        $mobileWrapper.append(mobilePanel);

        $('.d-o-header__collapse-header-right').prepend($mobileWrapper);
    }

    if (exceedsMaximumResolution(767) && !exceedsMaximumResolution(1264)) {
        if (!$('.d-c-header').hasClass('d-t-header--new')) {
            $('.d-o-header__mobile-buttons').append($('#d-js-search__toggle'));
        }
    }

    if (!$('.d-c-header').hasClass('d-t-header--new')) {
        if ($('.d-o-header__tablet-search.d-t-search--active').length === 0) {
            if (exceedsMaximumResolution(767)) {
                $('.d-o-header__tablet-search').append($('.d-o-header__search-container'));
            }
        } else {
            $('.d-o-header__tablet-search').append($('.d-o-header__search-container'));
        }
    }

    resizeComponent(function () {
        if (exceedsMaximumResolution(1264)) {
            $('.d-o-header__dropdown-lvl-2-container').css('min-width', '1136px');
            // if ($('.d-c-preheader__container').find('.d-c-preheader__accessibility').length === 0) {
            //     $('.d-c-preheader__container').append($('.d-c-preheader__accessibility'));
            // }
            if (!$('.d-c-header').hasClass('d-t-header--new')) {
                if ($('.d-o-header__desktop-buttons').find('.d-o-header__collapse-footer-button').length === 0) {
                    $('.d-o-header__desktop-buttons').prepend($('.d-o-header__mobile-buttons-login'));
                    $('.d-o-header__desktop-buttons').prepend($('.d-o-header__collapse-footer-button'));
                }
            }

            $('.d-c-preheader__accessibility').remove();

            const $desktopWrapper = $('<div class="d-c-preheader__accessibility"></div>');
            const desktopPanel = document.createElement('dav-accessibility-panel');
            desktopPanel.setAttribute('panel-title', 'Panel de accesibilidad');
            desktopPanel.setAttribute('title-icon', 'accessibility');
            $desktopWrapper.append(desktopPanel);

            $('.d-c-preheader__container').append($desktopWrapper);

        } else {
            $('.d-o-header__dropdown-lvl-2-container').css('min-width', 'unset');

            // mobile: recrear de nuevo correctamente
            // const $target = $('.d-o-header__collapse-header-right');
            $('.d-c-preheader__accessibility').remove();

            const $mobileWrapper = $('<div class="d-c-preheader__accessibility"></div>');
            const mobilePanel = document.createElement('dav-accessibility-panel');
            mobilePanel.setAttribute('panel-title', 'Panel de accesibilidad');
            mobilePanel.setAttribute('title-icon', 'accessibility');
            $mobileWrapper.append(mobilePanel);

            $('.d-o-header__collapse-header-right').prepend($mobileWrapper);

            if (!$('.d-c-header').hasClass('d-t-header--new')) {
                if ($('.d-o-header__collapse-footer').find('.d-o-header__collapse-footer-button').length === 0) {
                    $('.d-o-header__mobile-buttons').prepend($('.d-o-header__mobile-buttons-login'));
                    $('.d-o-header__collapse-footer').prepend($('.d-o-header__collapse-footer-button'));
                }
            }

            
        }

        if (!$('.d-c-header').hasClass('d-t-header--new')) {
            if (exceedsMaximumResolution(767) && !exceedsMaximumResolution(1264)) {
                $('.d-o-header__mobile-buttons').append($('#d-js-search__toggle'));
            } else {
                $('.d-o-header__desktop-buttons').append($('#d-js-search__toggle'));
            }
        }

        if (!$('.d-c-header').hasClass('d-t-header--new')) {
            if ($('.d-o-header__tablet-search.d-t-search--active').length === 0) {
                if (exceedsMaximumResolution(767)) {
                    $('.d-o-header__tablet-search').append($('.d-o-header__search-container'));
                } else {
                    $('.d-o-header__search').append($('.d-o-header__search-container'));
                }
            }
        }
    });
}

    //Genera las animaciones al desplegar los dropdowns en desktop
    function heightMenus(classResize) {
        if(exceedsMaximumResolution(1264)) {
            if(classResize != '') {
                $(".d-js-header__toggle-lvl-2").each(function(){
                    $(this).addClass(classResize)
                })
            }
            $(".d-js-header__toggle-lvl-2").off('click.dropdownsLevel2resize')
            $('header .d-o-header__dropdown-lvl-1').addClass('d-block');
            $('header .d-o-header__dropdown-lvl-2').addClass('d-block');
            $('header .d-o-header__dropdown-lvl-3').addClass('d-block');
            var arrayHeights = []
            var arrayHeightsLvl3 = []
            
            $(".d-js-header__toggle-lvl-2").each(function(){
                if(exceedsMaximumResolution(1264)) {
                    var $content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-2-height");
                    var $contentStyles = $content.find(".d-o-header__dropdown-lvl-2-container");
                    var ulHeight = 0;

                    $content.removeAttr('style')
                    $contentStyles.removeClass("d-o-header__dropdown-lvl-2-container--float");
                    
                    $content.find('.d-js-header__dropdown-calc').each(function() { 
                        var currentHeight = $(this).outerHeight();
                        currentHeight = currentHeight + 80;
                        if (currentHeight > ulHeight) {
                            ulHeight = currentHeight; 
                        }
                    });
                    arrayHeights.push(ulHeight+72);
                    $content.css("height", ulHeight+"px");
                    $content.css("max-height", ulHeight+"px");
                    $contentStyles.addClass("d-o-header__dropdown-lvl-2-container--float");
                }
            });
            
            $(".d-js-header__lvl3").each(function(){
                var currentHeight = $(this).parents("li").eq(0).find("ul").outerHeight()
                currentHeight = currentHeight + 80
                arrayHeightsLvl3.push(currentHeight+72);
            });
            $('header .d-o-header__dropdown-lvl-1').removeClass('d-block');
            $('header .d-o-header__dropdown-lvl-2').removeClass('d-block');
            $('header .d-o-header__dropdown-lvl-3').removeClass('d-block');

            $(".d-js-header__toggle-lvl-2").on( 'click.dropdownsLevel2resize',function(e){
                //$(this).addClass('hasResize');
                if(exceedsMaximumResolution(1264)) {
                    var index = $(".d-js-header__toggle-lvl-2").index(this); 
                    if($(this).attr('aria-expanded') == 'false') {
                        console.log('me ejecuto 0 '+ $(this).attr('aria-expanded'))
                        console.log(arrayHeights[index])
                        $(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height', arrayHeights[index] + 'px');
                        $(this).parents('.d-o-header__dropdown-lvl-1').css("height", arrayHeights[index]+"px");
                    } else {
                        if($(this).hasClass('hasResize')) {
                            console.log('me ejecuto 2')
                            $(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height', '72px');
                            $(this).parents('.d-o-header__dropdown-lvl-1').css("height", "72px");
                            //$(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height', arrayHeights[index] + 'px');
                            //$(this).parents('.d-o-header__dropdown-lvl-1').css("height", arrayHeights[index]+"px");
                        } else {
                            console.log('me ejecuto 3')
                            $(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height', '72px');
                            $(this).parents('.d-o-header__dropdown-lvl-1').css("height", "72px");
                        }
                    }
                    closeAlldropdownsLvl3();
                }
            })
            $(".d-js-header__lvl3").click(function(e){
                if(exceedsMaximumResolution(1264)) {
                    var sizeActual = $(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height');
                    var index = $(".d-js-header__lvl3").index(this); 
                    if(arrayHeightsLvl3[index] > parseInt(sizeActual)) {
                        $(this).parents("li").find(".d-o-header__dropdown-lvl-2-height").css('height', arrayHeightsLvl3[index] + 'px');
                        $(this).parents("li").find(".d-o-header__dropdown-lvl-2-height").css('max-height', arrayHeightsLvl3[index] + 'px');
                        $(this).parents('.d-o-header__dropdown-lvl-1').css('--menu-height', arrayHeightsLvl3[index] + 'px');
                        $(this).parents('.d-o-header__dropdown-lvl-1').css('height', arrayHeightsLvl3[index] + 'px');
                    }
                }
            })
            $(".d-js-header__toggle-carousel").off('click.resizeHeaderDropdowns');
            $(".d-js-header__toggle-carousel").on('click.resizeHeaderDropdowns',function(e){
                if(exceedsMaximumResolution(1264)) {
                    closeSearch();
                    closeAlldropdownsLvl3();
                    var $button = $(this);
                    var $content = $(this).parents(`.d-o-dropdown`).eq(0).find(`.d-js-dropdown__content`);
                    var isExpanded = $button.attr('aria-expanded') === 'true';
                    var $itemsContent = $content.find('.d-js-header__toggle-lvl-2')
                    closeAllDropdownslvl2();
                    if(!isExpanded) {
                        if($itemsContent.length == 1) {
                            $content.addClass('d-js-dropdown-lvl2--active')
                            $itemsContent.eq(0).trigger('click');
                            $itemsContent.eq(0).prop('disabled', true);
                            $itemsContent.parents('.d-o-header__carousel-li').find('.d-o-header__dropdown-lvl-2').addClass('d-js-header--force-active');
                        } else {
                            $content.css('--menu-height', '72px');
                            $content.css('height', '72px');
                        }
                        $(this).addClass(`${window.prefixClass.js}--active`);
                        $content.removeClass('d-js-lvl2--expanded');
                        if($itemsContent.length == 1) {
                            
                        }
                        closeMenuDropdowns();
                    } else {
                        $(this).removeClass(`${window.prefixClass.js}--active`);
                    }
                    toggleMenu($(this), $content, 'open', 'closing', true);
                    
                }
            });
            
        } else {
            $(".d-js-header__toggle-lvl-2").each(function(){
                var $content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-2-height");
                var $contentStyles = $content.find(".d-o-header__dropdown-lvl-2-container");
                $content.attr('style', '');
                $contentStyles.removeClass("d-o-header__dropdown-lvl-2-container--float");
                $content.find(".d-o-header__dropdown-lvl-3").each(function(){
                    $(this).find("ul").attr("style", "");
                });
            })
        }
    }
    resizeComponent(heightMenus('hasResize'));
    //Inicializacion general del componente.
    function initComponent() {
        sizeMenuMobile();
        burgerMenu('#burgerMenu');
        carrouselMenu();
        dropdownsLvl1();
        dropdownsLvl2();
        dropdownsLvl3();
        searchHeader();
        interactionPreHeaderAndSearch();
        changeHTML();
        
        setTimeout(() => {
            $('.d-o-header__collapse-content').css('height', '');
            sizeMenuMobile(); // recalcula después de que todo se haya renderizado
        }, 500);
    }
    initComponent()

    // Ajustar menú también en resize
//     function onResizeHeader() {
//     heightMenus();
//     sizeMenuMobile();
//     changeHTML();
//     closeMenuDropdowns();
//     closeAllDropdownslvl2();
//     closeAlldropdownsLvl3();
//     closeSearch();
//     $('body').removeClass('not-scroll');
// }
// resizeComponent(onResizeHeader);

}


function huInterlinking() {

    function initComponent() {
        $(document).ready(function() {
            /* Obtenemos las categorias del interlinking */
            const categories = document.querySelectorAll('#d-js-interlinking__category');

            /* Iteramos las categorias */
            categories.forEach(category => {
                /* Seleccionamos el contenedor que tiene mas enlaces de la categoria */
                const moreOptions = category.querySelectorAll('.more-options');
                /* Seleccionamos el boton que muestra los enlaces ocultos de la categoria */
                const toggleMoreBtn = category.querySelector('.toggle-more');
                /* Seleccionamos las opciones/enlaces de la categoria */
                const options = category.querySelectorAll('.d-c-interlinking__category-options li');

                // Ocultar el botón "Mostrar más" si hay 3 o menos opciones
                if (options.length <= 3) {
                    toggleMoreBtn.style.display = 'none';
                }

                /* Agregamos el evento de click al boton de mostrar mas */
                toggleMoreBtn.addEventListener('click', () => {
                    /* Preguntamos si los enlaces se encuentran ocultos */
                    const isHidden = moreOptions[0].classList.contains('hidden');
                    /* Seleccionamos el contenedor de los enlaces del boton mostrar mas al que dimos click */
                    const listContainer = $(toggleMoreBtn).siblings(".d-c-interlinking__category-options");
                    const moreOptionsContainer = $(listContainer).find(".more-options");
                    

                    $(".d-c-interlinking__category-options").removeClass('expanded');

                    // Contraer otras categorías abiertas
                    categories.forEach(otherCategory => {
                        if (otherCategory !== category) {
                            const otherMoreOptions = otherCategory.querySelectorAll('.more-options');
                            const otherToggleMoreBtn = otherCategory.querySelector('.toggle-more');

                            otherMoreOptions.forEach(option => option.classList.add('hidden'));
                            if (otherToggleMoreBtn) {
                                otherToggleMoreBtn.textContent = 'Mostrar más';
                            }
                        }
                    });

                    // Alternar la visualización de la categoría actual
                    if (isHidden) {
                        $(listContainer).addClass('expanded');
                        moreOptions.forEach(option => option.classList.remove('hidden'));
                        toggleMoreBtn.textContent = 'Mostrar menos';
                    } else {
                        $(listContainer).removeClass('expanded');
                        moreOptions.forEach(option => option.classList.add('hidden'));
                        toggleMoreBtn.textContent = 'Mostrar más';
                    }
                });
            });
        });
    }

    initComponent();

   
}
