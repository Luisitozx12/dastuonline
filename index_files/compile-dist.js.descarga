function guiaDeAliados() {
    function initComponent() {      
        document.addEventListener("DOMContentLoaded", function() {
            const clickableCards = document.querySelectorAll('.d-c-guiaDeAliados__card-item--clickable');
            clickableCards.forEach(card => {
                card.addEventListener('click', function(event) {
                    const isPressed = card.getAttribute('data-pressed') === 'true';
                    card.setAttribute('data-pressed', isPressed ? 'false' : 'true');
                  
                });
            });

           
            
        });
        
        
   
        

    }

    initComponent();
}

guiaDeAliados();















