/******/ (function() { // webpackBootstrap
var __webpack_exports__ = {};
window.resolutionPrevious = $(window).innerWidth(); //Contiene el tamaño previo de la pantalla del usuario
window.resolutionCurrent = $(window).innerWidth(); //Contiene la resolucion ACTUAL de la pantalla del usuario
window.layout = {
    containerDesktop: 1136,
    containerBigDesktop: 1136
}; 
//Configure tamaños del container en escritorio [containerDesktop, containerBigDesktop]
window.breakPoints = {
    resolutionMinMobile: 360, 
    resolutionMinTablet: 767, 
    resolutionMinDesktop:1280,
    resolutionBigDesktop: 1280
};
window.prefixClass = {
    theme: "theme-D",
    component: "d-c",
    object: "d-o",
    style: "d-t",
    js: "d-js"
} 
/*
    Funcion: Resolucion actual y anterior // resolutionFunction()
    Retorna: null
    Descripcion: Se encarga de capturar la resolucion actual y anterior
    del usuario y guarda el dato en las variables globales resolutionPrevious y resolutionCurrent
    EJ: resolutionFunction()
*/
window.resolutionFunction = function () {
    let resolutionAux = window.resolutionCurrent;
    window.resolutionCurrent = $(window).innerWidth();
    if (resolutionAux != window.resolutionPrevious && window.resolutionCurrent != window.resolutionPrevious) {
        window.resolutionPrevious = resolutionAux;
    }
}

/*
    Funcion: actualizar resolucion a actual y anterior en tiempo real
    Retorna: null
    Descripcion: Se encarga de capturar la resolucion actual y anterior
    del usuario y guarda el dato en las variables globales resolutionPrevious y resolutionCurrent
    adicinalmente con esta funcion se actualiza de manera automatica.
    EJ: actualizeVarsResolution()
*/
window.actualizeVarsResolution = function () {
    resizeComponent(function(){
        resolutionFunction();
    });
}
/*
    Funcion: Exede resolucion maxima? // exceedsMaximumResolution(resolucionMaxima)
    Retorna: Booleano
    Descripcion: se encarga de valida si la pantalla del usuario supera un resolucion en especifico
    devuelve verdadero en caso de que el usuario supere la resolucion indicada
    devuelve falso en caso de que el usuario este en una resolucion menor a la indicada
    EJ: 
        if (exceedsMaximumResolution(500)) {
            codigo si exeder la resolucion permitida
        } else {
            codigo si esta dentro del rango permitido
        }
*/
window.exceedsMaximumResolution = function (resolutionMax) {
    if (!window.matchMedia("(max-width: " + resolutionMax + "px)").matches) {
        return true;
    } else {
        return false;
    }
}
/*
    Funcion: resize de pantalla // resizeComponent(funcionAEjecutarAlResize())
    Retorna: null
    Descripcion: detecta cada cambio en la resolucion y ejecuta la funcion 
    pasada en el parametro cada vez que la resolucion cambia
    NOTA: ESTO ES UN CALLBACK SE DEBE PASAR UNA FUNCION COMO PARAMETRO
    EJ: 
        resizeComponent(function (){
            //codigo del resize
            console.log('se ha cambiado la resolucion');
        });
*/
window.resizeComponent = function (callback) {
    let resizerTimer; 
    $(window).resize(function () {
        if (resizerTimer) clearTimeout(resizerTimer);
        resizerTimer = setTimeout(function () {
            callback();
        }, 300);
    });
}
/*
    Funcion: container actual // actualityContainer()
    Retorna: number
    Descripcion: se encarga de valida que tamaño tiene el layout
    segun la resolucion actual del usuario
    EJ: 
        let container = actualityContainer()
*/
window.actualityContainer = function () {
    let container = 0;
    if (window.resolutionCurrent > window.breakPoints.resolutionMinDesktop && window.resolutionCurrent < window.breakPoints.resolutionBigDesktop) {
        container = window.layout.containerDesktop;
    } else if (window.resolutionCurrent >= window.breakPoints.resolutionBigDesktop) {
        container = window.layout.containerBigDesktop;
    }
    return container;
}
/*
    Funcion: Agregar margin al contenedor // addLayoutContainer()
    Retorna: null
    PARAMETROS: 
        component : un componente en jquery
        position : 
            r : left
            l : right
            x : left y right
    Descripcion: Agrega un margin al que respeta el contenedor del sitio.
    
    EJ: 
        addLayoutContainer($(".miComponenteSinLayout"), "l");
*/
window.addLayoutContainer = function (component, position) {
    let container = actualityContainer();
    if (container != 0) {
        let margin = (window.resolutionCurrent - container) / 2;
        switch (position) {
            case "l":
                margin = "margin-left: " + margin + "px;";
                break;
            case "r":
                margin = "margin-right: " + margin + "px;";
                break;
            case "x":
                margin = "margin: 0px " + margin + "px;";
                break;
        }
        component.attr("style", margin);
    }
}
/*
    Funcion: Agregar margin al contenedor // addLayoutContainer()
    Retorna: null
    PARAMETROS: 
        component : un componente en jquery
        position : 
            r : left
            l : right
            x : left y right
    Descripcion: Agrega un margin al que respeta el contenedor del sitio.
    adicionalmente a eso este se actualiza con cada risize de pantalla
    
    EJ: 
        addLayoutContainer($(".miComponenteSinLayout"), "l");
*/
window.addLayoutContainerResponsive = function (component, position) {
    addLayoutContainer(component, position);
    resizeComponent(function(){
        addLayoutContainer(component, position);
    });
}
/*
    Funcion: Mover HTML // moveHTML(elementoAMover, contenedor)
    Retorna: null
    Descripcion: Mueve un contenedor especifico a un contenedor indicado
    NOTA: LOS PARAMETROS SE PASAN EN JQUERY
    EJ: 
        moveHTML($(.elementoAMover), $(.contenedorDeDestino));
*/
window.moveHTML = function (movedContainer, containerDestination) {
    containerDestination.append(movedContainer);
}
/*
    Funcion: Cortar caracteres // cutCharacters()
    Retorna: undefined
    Descripcion: se encarga de cortar un texto SIMPLE al numero de caracteres propuesto.
    EJ: 
        cutCharacters($(´.v-t-footer__text´), 55);
*/
window.cutCharacters = function ($text, maxCharacters) {
    if ($text.text().trim().length > maxCharacters) {
        $text.text($text.text().trim().substring(0, maxCharacters) + '...');
    }
    return;
}
function activateDropodowns() {
    
    var nameObject = 'dropdown';
    var object = window.prefixClass.object + "-" + nameObject;
    var objectJS = window.prefixClass.js + "-" + nameObject;
    var $preheaderItems = $(`.d-c-preheader ul .item`);
    var preheaderData = [];
    if($preheaderItems.length > 0) {
        $preheaderItems.each(function(){
            preheaderData.push($(this).hasClass("d-t-btn-preheader--active"))
        });
    }
    function removeDataPreHeader() {
        let index = preheaderData.findIndex(item => item == true);
        $preheaderItems.eq(index).removeClass('d-t-btn-preheader--active');
    }
    function addDataPreHeader() {
        let index = preheaderData.findIndex(item => item == true);
        $preheaderItems.eq(index).addClass('d-t-btn-preheader--active');
    }
    $('#d-js-header__collapse--close').click(function(){
        addDataPreHeader();
    });

      // Prevent propagation for clicks inside the dropdown
      $(`.${objectJS}__content`).on('click', function (e) {
        e.stopPropagation();  // Prevent event from bubbling up to the parent
    });


    let isClicking = false;
    //console.log(isClicking)
    
    $(`.${objectJS}`).click(function (e) {
        e.preventDefault();
        e.stopPropagation();
       
        
       
        let resolutionValidate = false;
        if ($(this).hasClass(`${objectJS}--not-desktop`)) {
            if (!exceedsMaximumResolution(1264)) {
                resolutionValidate = true;
            }
        } else if ($(this).hasClass(`${objectJS}--not-mobil`)) {
            if (exceedsMaximumResolution(1264)) {
                resolutionValidate = true;
            }
        } else {
            resolutionValidate = true;
        }
       
        if (resolutionValidate) {
            if (!exceedsMaximumResolution(1264)){               
                let isNewPreheader = $(this).parents('.d-c-preheader').hasClass('d-t-preheader--new');    
                // Si el dropdown tiene un padre con la clase "new" y está abierto, no hacer nada
                if (isNewPreheader && $(this).attr("aria-expanded") == "true") {                   
                    return;  // Si está abierto, no hacer nada
                }
            }           
            if(!$(this).hasClass("d-js-header__toggle-carousel") || ($(this).hasClass("d-js-header__toggle-carousel") && !exceedsMaximumResolution(1264))) {
                let content = $(this).parents(`.${object}`).find(`.${objectJS}__content`);
                let allDrops = $(this).parents("ul").eq(0);        
                content.slideToggle(600); 
                $(this).attr("aria-expanded", function (index, attr) {
                    return attr == "true" ? "false" : "true";               
                });
                 
                if ($(this).attr("aria-expanded") == "true") {
                    $(this).addClass(`${window.prefixClass.js}--active`);
                                         
                     console.log("abriendo el drop");

                    if($(this).parents(".d-c-preheader").length > 0){
                       
                        if(resolutionCurrent <1264){
                            removeDataPreHeader();
                            setTimeout(() => {
                                $(this).closest(".has-dropdown-btn").addClass('fondo-white-preheaderLi');
                            }, 1000); 

                            $(".d-o-header__search").addClass("hiddeTanHeadder");
                            $(".d-o-header__desktop-menu").addClass("hiddeTanHeadder");
                            $(".d-o-header__collapse-footer").addClass("hiddeTanHeadder");
                                             
                            $('.d-c-preheader-line').removeClass('d-c-preheader-red-line');
                            $('.d-c-preheader-line').addClass('d-c-preheader-gray-line');
                            $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').removeClass('d-c-preheader-gray-line');
                            $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').addClass('d-c-preheader-red-line');
                            
                            var parentElement = $(this).parent(".d-o-dropdown");                           
                                parentElement.addClass('highlight');                                                      
                                                     
                        }

                        else{
                            $(".d-t-dropdown__content").removeClass("d-t-dropdown__content-animationRever");
                            $(".d-t-dropdown__content").addClass("d-t-dropdown__content-animation");
                            console.log("abriendo")

                         
                                isClicking = true;
                                console.log("cambiando iscliking a true")
                                

                          

                        }
                    }
                    //clases agregadasal abrir el dropdown del preheader
                } else {
                    $(this).removeClass(`${window.prefixClass.js}--active`);
                    $(".d-t-dropdown__content").addClass("d-t-dropdown__content-animationRever");
                    $(".d-t-dropdown__content").removeClass("d-t-dropdown__content-animation");
                    console.log("cerrando")
                    if($(this).parents(".d-c-preheader").length > 0){
                        
                        $(".d-t-dropdown__content").removeClass("d-t-dropdown__content-animation-opacity");
                        if(resolutionCurrent <1264){

                            $(".d-o-header__search").removeClass("hiddeTanHeadder");
                            $(".d-o-header__desktop-menu").removeClass("hiddeTanHeadder");
                            $(".d-o-header__collapse-footer").removeClass("hiddeTanHeadder");


                            $(this).closest(".has-dropdown-btn").removeClass('fondo-white-preheaderLi');

                                addDataPreHeader();
                                $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').addClass('d-c-preheader-gray-line');
                                $(this).parent(".d-o-dropdown").parent(".d-c-preheader-item").find('.d-c-preheader-line').removeClass('d-c-preheader-red-line');
                                var parentElement = $(this).parent(".d-o-dropdown");
                                parentElement.removeClass('highlight');                          
                        }
                        else{
                            console.log("cerrando iscliking false")
                            isClicking = false;
                            
                        }
                    }
                }
                 
                if (allDrops.hasClass(`${objectJS}s`)) {
                    allDrops.find(`.${objectJS}`).not(this).each(function () {
                        console.log("probando funcion")
                        if ($(this).attr("aria-expanded") == "true") {
                            
                            let content = $(this).parents(`.${object}`).find(`.${objectJS}__content`);
                            //$content.removeClass("d-t-dropdown__content-animation-opacity");
                            content.slideUp(300);
                            $(this).attr("aria-expanded", "false");
                            $(this).removeClass(`${window.prefixClass.js}--active`);
                        }
                    });
                }
                if($(this).parents(".d-c-header").length == 0) {
                    content.css('left', '');
                    content.css('right', '');
                    if (exceedsMaximumResolution(1264)) {
                        let contentOffset = content.offset().left;
                        let contentWidth = content.outerWidth();
                        let bodyWidth = $('body').width();
                        if (contentOffset + contentWidth > bodyWidth) {
                            content.css('left', 'unset');
                            content.css('right', '0px');
                        }
                    }
                } 
            }
        }
    });
    


    

    
    function closeSearch() {
        if ($(".d-o-header__search-toggle").attr("aria-expanded") == "true") {
            $(".d-o-header__tablet-search").removeClass('open').addClass("closing");
            setTimeout(function () {
                $(".d-o-header__tablet-search").css('display', 'none');
                $(".d-o-header__tablet-search").removeClass("closing");
            }, 550);
            $(".d-o-header__search-toggle").attr("aria-expanded", "false");
            $(".d-o-header__search-toggle").removeClass("d-js--active")
        }
    }
    var isProcessing = false;
    
    // $(`.${objectJS}.d-js-header__toggle-carousel`).on('mouseenter',
    //     function() {
    //         var $button = $(this);
