    function updateTotalWidth() {
        let totalWidth = 0;
        const $container = $('.d-c-preheader-btn-group_container');
    
        if ($container.length > 0) {
            const $leftControl = $('.d-o-controller__icon-preheader-left');
            const $rightControl = $('.d-o-controller__icon-preheader-right');
            const isActive = $leftControl.css('display') === 'block' ||
                $leftControl.css('display') === 'flex' ||
                $rightControl.css('display') === 'block' ||
                $rightControl.css('display') === 'flex';
    
            if (isActive) {
                // Calcular el ancho total de los elementos del carrusel
                $('.d-c-preheader-item').each(function () { 
                    // Verifica que el elemento no tenga la clase 'item-side'
                    if (!$(this).hasClass('item-side')) {
                        totalWidth += $(this).outerWidth(true);
                    }
                });
                $container.css('--after-width', `${totalWidth}px`);
                //console.log("linea con carrusel");
            } else {
                // Establecer el ancho en 100% cuando el carrusel no esté activo
                $container.css('--after-width', `100%`);
                //console.log("linea sin carrusel");
            }
        }
        return totalWidth;
    }

        $(document).ready(function() {
            initialize();
        });


        function initialize() {
            totalWidth = updateTotalWidth(); 
        }
        initialize();
      

        $(window).on('resize', function() {
            updateTotalWidth(); 
            initialize();
        });
       
      

        $('#d-js-preheader-btn-group .item').each(function(index) {
            // Verificar que el padre del elemento no tenga la clase 'item-side'
            if (!$(this).closest('.item-side').length) {
                $(this).attr('data-index', index + 1);
                $(`#d-js-preheader-btn-group .d-c-preheader-red-line`).eq(index).attr('data-index', index + 1);
            }
        });

        let lastTabIndex = null;

        $(".d-c-preheader-item").find('.item').on('click', function() {
            const $currentTab = $(this);
            const currentIndex = $currentTab.data('index');
            const $currentLine = $(".d-c-preheader-line");
    
            if (lastTabIndex === null) {
                lastTabIndex = currentIndex;
                return;
            }
            const direction = currentIndex > lastTabIndex ? 'right' : 'left';    
            if (direction === 'right') {
                $currentLine.addClass('animate-right');
            } else {
                $currentLine.addClass('animate-left');
            }
            lastTabIndex = currentIndex;
            setTimeout(() => {
                $currentLine.removeClass('animate-right animate-left');
            }, 600);
        });

        $(".d-c-preheader-item").find('.d-t-dropdown__btn').on('click', function() {
            const $currentTab = $(this);
            const $parent = $currentTab.closest('[data-index]');
            const currentIndex = $parent.data('index'); // Obtiene el índice del elemento padre
            const $currentLine = $(".d-c-preheader-line");

    
            if (lastTabIndex === null) {
                lastTabIndex = currentIndex;
                return;
            }
            const direction = currentIndex > lastTabIndex ? 'right' : 'left';    
            if (direction === 'right') {
                $currentLine.addClass('animate-right');
            } else {
                $currentLine.addClass('animate-left');
            }
            lastTabIndex = currentIndex;
            setTimeout(() => {
                $currentLine.removeClass('animate-right animate-left');
            }, 600);
        });

   
    
        function updateButtonStates() {
            if ($container.length === 0) {
                return; 
            }
    
            const currentScroll = $container.scrollLeft();
            const maxScroll = Math.floor($container[0].scrollWidth - $container.outerWidth());
    
            if (currentScroll <= 0) {
                $scrollLeft.addClass('disabled').removeClass('active');
            } else {
                $scrollLeft.removeClass('disabled').addClass('active');
            }
    
            if (currentScroll >= maxScroll) {
                $scrollRight.addClass('disabled').removeClass('active');
            } else {
                $scrollRight.removeClass('disabled').addClass('active');
            }
        }

