//3. cerrar el dropdpwn con escape
$(".d-t-preheader--new .d-t-dropdown__item").on("focus", function(e) {
    const content = $(this).closest('.d-t-dropdown__content');
    $(this).on("keydown", function(e) {
        if (e.key === "Escape") { 
            e.preventDefault(); 
            //btnTab.trigger("click");
            $(this).closest(".has-dropdown-btn").removeClass('fondo-white-preheaderLi');
            $('.d-t-dropdown__btn').attr("aria-expanded", "false");
            content.stop(true, true).slideUp(600).removeClass('expand').addClass('rebounce');  
            content.addClass("d-t-dropdown__content-animationRever");                   
        }
    });
});


//4. Navegando con tab dentro del menu
//4.1 manejamos el cierre del dropdpom en la navegacion por tab( cerrar al navegar del ultimo item del desplegable)
function adjustDropdownHeight() {
    $('.d-c-preheader').find('.d-o-dropdown').each(function() {
        const $containerBoxes = $(this).find('.d-t-dropdown__container-box');
        let $lastItem = $();
        $containerBoxes.each(function(index) {
            const $items = $(this).find('.d-t-dropdown__item');
            if ($items.length > 0) {
                $lastItem = $items.last();
            }
        });
        if ($lastItem.length > 0) {
            $lastItem.off('blur').on('blur', function() {
                if (exceedsMaximumResolution(1264)) {
                    // Elimina las clases de estilo
                    $('#d-js-preheader-btn-group').find(".d-t-dropdown__container .container").removeClass('fontNormal');
                    $('#d-js-preheader-btn-group').find(".item").removeClass('fontNormal');
                    $('#d-js-preheader-btn-group').find(".d-t-dropdown__btn").removeClass('fontNormal');
                    clearTimeout(closeTimeout);                   
                    // Itera sobre cada botón del dropdown
                    $(this).closest('.d-t-dropdown').find(`.${objectJS}.d-t-dropdown__btn-preheader`).each(function() {
                        if ($(this).attr("aria-expanded") === "true") {
                            let content = $(this).parents(`.${object}`).find(`.${objectJS}__content`);
                            content.removeClass("d-t-dropdown__content-animation");
                            content.addClass("d-t-dropdown__content-animationRever");
                            content.stop(true, true).slideUp(600).removeClass('expand').addClass('rebounce');
                            $(this).attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
                        }
                    });
                }
            });
        }
    });
}

if (!$('body').hasClass('has-edit-mode-menu')){
    adjustDropdownHeight();
}

$(window).resize(adjustDropdownHeight);

function adjustContentPosition($content) {
    $content.css('left', '');
    $content.css('right', '');

    if (exceedsMaximumResolution(1264)) {
        let contentOffset = $content.offset().left;
        let contentWidth = $content.outerWidth();
        let bodyWidth = $('body').width();

        if (contentOffset + contentWidth > bodyWidth) {
            $content.css('left', 'unset');
            $content.css('right', '0px');
        }
    }
}

