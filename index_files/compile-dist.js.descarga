function Cookies () {
    function initComponent () {

      setTimeout(function() {
        $(".d-c-cookies").removeClass("dnone");
    }, 1000); 

  //realizamos cambio de tamaño del parrafo dependiendo de la resolución de la pantalla
      function adjustsizeParagraphCookies() {    
        var resolutionCurrent = $(window).width();
        if (resolutionCurrent < 1279) {         
            $(".d-c-cookies").find('.d-c-cookies__paragraph').find(".d-c-cookies__dav-paragraph").attr('size', '2xs');
        } 
        else {          
          $(".d-c-cookies").find('.d-c-cookies__paragraph').find(".d-c-cookies__dav-paragraph").attr('size', 'xs');
      }
    }
 //asignamos y eliminamos la clase container segun la resolucón
    if (resolutionCurrent < 768){
      $(".d-c-cookies").find('.d-c-cookies__container').addClass('container');

    }else{
      $(".d-c-cookies").find('.d-c-cookies__container').removeClass('container');

    }
    adjustsizeParagraphCookies();
    $(window).resize(function() {
      adjustsizeParagraphCookies();
    });

    var $cookie = $(".d-c-cookies");
    var $content = $cookie.find('.d-c-cookies__content');
    
    // Aplicamos la animación de entrada al contenido cuando aparece
    //$cookie.addClass('moveIn');

    $(".dav-button-cookies").click(function() {
      var $cookie = $(".d-c-cookies");
      var $content = $cookie.find('.d-c-cookies__content');
      
      // Eliminar la clase de animación de entrada (MoveIn)
      $cookie.css('animation', 'none');
      $cookie.css('animation', 'slideDownBounce 1s forwards');

      $cookie.on('animationend', function() {
        // Ocultamos el banner con display: none después de la animación
        $(this).css('display', 'none');
      });

  });

  
   
  }
    

    
    initComponent();
  
}
function Growl () {
    function initComponent () {
        if ($(".d-c-growl").length > 0) {

            $(this).removeClass("d-none");

        // Funcion para Cuando se hace clic en el botón de cierre el banner
        $(".d-c-growl__close").click(function() {
            $(".d-c-growl").css('animation', 'none');
            $(".d-c-growl").css('animation', 'slideDownBounce 0.3s ease-in forwards');
                    

            setTimeout(function() {
                $(".d-c-growl").addClass('d-none'); 
            }, 400); 

        });


      

        // Cuando la página y los recursos estén completamente cargados
        $(window).on('load', function() {
            // Esperamos 2 segundos antes de mostrar el banner con la animación
            setTimeout(function() {
                // Eliminamos la clase 'dnone' para hacer visible el banner
                $(".d-c-growl").removeClass("d-none");
                // Aplicamos la clase para la animación de salto
                $(".d-c-growl").addClass("showGrowl");
            }, 1000); // 2000 ms = 2 segundos de retraso
        });


        //enfocamos el icono de la x
        $('.d-c-growl__close').on('keydown', function(event) {
            if (event.key === "Enter" || event.keyCode === 13) {
                // Simula un clic en el botón de cierre
                $(".d-c-growl__close").click();
            }
        });

        // Esperamos 6 segundos después de que la página se haya cargado y cookies haya desaparecido   
            // Después de 6 segundos, eliminamos la clase hideGrowl (si existe)
            $(".d-c-growl").removeClass('hideGrowl');
            //$(".d-c-growl").addClass('showGrowl');     
        }


//agregamos un scroll a los 8 segundo dando tiempo que se calcule la altura el banner 
setTimeout(function() {
    var $content = $('.d-c-growl');
    //$content.css('overflow-y', 'auto');
    $content.addClass('scrollable');
     }, 8000); 
     }

     
      
    initComponent();
   
}
function Inline () {
    function initComponent () {

        if ($(".d-c-inline-alert").length > 0){

            setTimeout(function() {
                $(".d-c-inline-alert").removeClass("dnone");
        
            }, 1000); 
            

            //$(this).removeClass("dnone");
            var $iconosDiv = $('.d-c-inline-alert__content-icon');
            var $textDiv = $('.d-c-inline-alert__text');
            var $alertContentDiv = $('.d-c-inline-alert__content'); 
      
            // Función para mover el div .d-c-inline-alert__text dependiendo del tamaño de la pantalla
            function ajustarUbicacion() {
                if (! exceedsMaximumResolution(1279)) { 
                    // Mover el div .d-c-inline-alert__text
                    if (!$textDiv.parent().is($alertContentDiv)) {
                        $alertContentDiv.append($textDiv); 
                    }
                } else {  
                    // Mover el div .d-c-inline-alert__text a su lugar original entre los iconos
                    if (!$textDiv.parent().is($iconosDiv)) {
                        $textDiv.insertAfter($('.d-c-inline-alert-icon:first'));  // Coloca el texto entre los iconos
                    }
                }
            }  
          
                function ajustarIconStart() {
                    if (exceedsMaximumResolution(1279)) {
                        var $contenedor = $('.d-c-inline-alert__content-icon');
                        var $icon = $('.d-c-inline-alert-icon.icon-information');  
                        var $contentIcon = $('.d-c-inline-alert__content-icon'); 
                        var $text = $('.d-c-inline-alert__text');   
                        var $iconClose = $('.iconClose');           
                        // Esperar un poco para que todo el contenido se renderice
                        setTimeout(function() {
                            var alturaContenedor = $contenedor[0].getBoundingClientRect().height;
                            console.log("Altura del contenedor después de renderizar: " + alturaContenedor);
            
                            if (alturaContenedor > 42) {
                                console.log("Mayor a 74, agregar la clase");
                                $icon.addClass('iconInlineStart');
                                $contentIcon.addClass('iconInlineStart');
                                $text.addClass('iconInlineStart');
                                $iconClose.addClass('inlineIconClose');
                            } else {
                                console.log("Menor a 74, quitar la clase");
                                $icon.removeClass('iconInlineStart');
                                $contentIcon.removeClass('iconInlineStart');
                                $contentIcon.addClass('inlineCenter');
                                $text.removeClass('iconInlineStart');
                                $text.addClass('inlineCenter');
                                $iconClose.removeClass('inlineIconClose');
                            }
                        }, 1000); // Esperar 100ms antes de calcular la altura
                    }
                }
            
                // Llamar a la función cuando el documento esté listo
                ajustarIconStart();
            
              


            
           
   
            $(".d-c-inline-close").click(function() {
                $(".d-c-inline-alert").addClass('hideInline');


                setTimeout(function() {
                    $(".d-c-inline-alert").addClass('dnone').css("display", "none"); ; 
                }, 400); 
            });
            // Llamar a la función cuando se cargue la página y cuando cambie el tamaño de la ventana
            $(window).resize(ajustarUbicacion);
            
            // Llamar a la función inicial
            ajustarUbicacion();

             //vamos a agregar una variante dependiendo si existe el icono de la izquierda o no
            if ($('dav-icon[name="information"]').length > 0) {
                // Si existe, verifica si los elementos tienen la clase 'noIcon' y, si la tienen, la elimina
                if ($('.d-c-inline-alert__content').hasClass('noIcon')) {
                  $('.d-c-inline-alert__content').removeClass('noIcon');
                }
                if ($('.d-c-inline-alert__content-icon').hasClass('noIcon')) {
                  $('.d-c-inline-alert__content-icon').removeClass('noIcon');
                }
                if ($('.d-c-inline-alert__text').hasClass('noIcon')) {
                  $('.d-c-inline-alert__text').removeClass('noIcon');
                }
              } else {
                // Si no existe el icono, agrega la clase 'noIcon'
                $('.d-c-inline-alert__content').addClass('noIcon');
                $('.d-c-inline-alert__content-icon').addClass('noIcon');
                $('.d-c-inline-alert__text').addClass('noIcon');
              }

      

            $('.d-c-inline-alert button').on('click keydown', function(event) { 
                if (event.type === "click" || event.key === "Enter" || event.key === " " || event.keyCode === 13 || event.keyCode === 32) {
                    event.preventDefault();
                    
                    // Cierra el banner
                    $(".d-c-inline-alert").addClass('hideInline');
                    
                    setTimeout(function() {
                        $(".d-c-inline-alert").addClass('dnone');
                    }, 400);
                }
            });
            
            
            
        


        $('.lfr-layout-structure-item-com-liferay-journal-content-web-portlet-journalcontentportlet').each(function() {
            if ($(this).find('.d-c-inline-alert').length) {
              $(this).addClass('d-t-inline--sticky');
            }
          });

          

        }

        
       


       



}
      
    initComponent();
   
}
function huCardInteractive() {
    //Rectifica si esta desplegada la card
    function isOpen (ariaExpand) {
        if(ariaExpand == 'true' || ariaExpand == true) {
            return true;
        } else {
            return false
        }
    }
    //Funcion abrir o cerrar card
    function toggleInteractiveCard($card) {
        var cardState = $card.attr('aria-expanded');
        var cardContent = $card.parents('.d-t-card-interactive__info');
        var cardBg = $card.parents('.d-t-card-interactive__front');
        if(isOpen(cardState)){
            $card.attr('aria-expanded', 'false');
            cardContent.removeClass('d-js-card-interactive__info--active');
            cardBg.removeClass('d-t-card-interactive__front--active')
        } else {
            $card.attr('aria-expanded', 'true');
            cardContent.addClass('d-js-card-interactive__info--active');
            cardBg.addClass('d-t-card-interactive__front--active')
            closeAllCard($card)
        }
    }
    //Cerrar todas las cards menos la activa
    function closeAllCard($activeCard) {
        $('.d-js-card-interactive__btn').not($activeCard).each(function(){
            var cardState = $(this).attr('aria-expanded');
            var cardContent = $(this).parents('.d-t-card-interactive__info');
            var cardBg = $(this).parents('.d-t-card-interactive__front');
            if(isOpen(cardState)) {
                $(this).attr('aria-expanded', 'false');
                cardContent.removeClass('d-js-card-interactive__info--active');
                cardBg.removeClass('d-t-card-interactive__front--active');
            }
        })
    }
    function initComponent() {
        $('.d-js-card-interactive__btn').click(function(){
            toggleInteractiveCard($(this));
        })
    }
    initComponent();
}
