     //Controla todas las interacciones del dropdown de nivel 2
    function dropdownsLvl2() {
        $(".d-js-header__toggle-lvl-2").click(function(e){
            e.preventDefault();
            var content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-2");
            var contentLvl1 = $(this).parents(".d-o-header__dropdown-lvl-1");
            let allDrops = $(this).parents("ul").eq(0);
            let actualScroll = $('.d-o-header__relative').scrollTop();
            if(!exceedsMaximumResolution(1264)) {
                content.slideToggle(600);
                $(this).attr("aria-expanded", function (index, attr) {
                    return attr == "true" ? "false" : "true";
                });
                if ($(this).attr("aria-expanded") == "true") {
                    $(this).addClass(`${window.prefixClass.js}--active`);
                    content.css('top', `${actualScroll}px`);
                    $('.d-o-header__desktop-menu').css("overflow", 'hidden');
                } else {
                    $(this).removeClass(`${window.prefixClass.js}--active`);
                    $('.d-o-header__desktop-menu').css("overflow", 'overlay');
                }
                allDrops.find(`.d-js-header__toggle-lvl-2`).not(this).each(function () {
                    if ($(this).attr("aria-expanded") == "true") {
                        let content = $(this).parents(`.d-o-header__carousel-li`).find(`.d-o-header__dropdown-lvl-2`);
                        content.slideUp(600);
                        $(this).attr("aria-expanded", "false");
                        $(this).removeClass(`${window.prefixClass.js}--active`);
                    }
                });
            } else {
                var hasDropdownActive = false;
                allDrops.find(".d-js-header__toggle-lvl-2").not($(this)).each(function(){
                    if ($(this).attr("aria-expanded") == "true") {
                        hasDropdownActive = true;
                    }
                });
                contentLvl1.removeClass("open");
                if($(this).attr('aria-expanded') === 'false') {
                    if(!$('.d-c-header').hasClass('d-t-header--new') || ($('.d-c-header').hasClass('d-t-header--new') && hasDropdownActive === false)) {
                        contentLvl1.addClass("d-js-lvl2--expanded");
                        $(this).addClass(`${window.prefixClass.js}--active`);
                        setTimeout(function () {
                            contentLvl1.removeClass("d-js-lvl2--expanded");
                        }, 550);
                        $(this).addClass(`${window.prefixClass.js}--active`);
                        closeMenuDropdownslvl2(allDrops);
                    } else {
                        contentLvl1.addClass("d-t-header--degrade");
                        setTimeout(function () {
                            contentLvl1.removeClass("d-t-header--degrade");
                        }, 550);
                        $(this).addClass(`${window.prefixClass.js}--active`);
                        closeMenuDropdownslvl2NotAnimation(allDrops);
                    }
                } else {
                    if($(this).parents('.d-o-header__carousel-li').find('.d-o-header__dropdown-lvl-2').hasClass('d-js-header--force-active')){
                        $(this).parents('.d-o-header__carousel-li').find('.d-o-header__dropdown-lvl-2').removeClass('d-js-header--force-active')
                    }
                    $(this).removeClass(`${window.prefixClass.js}--active`);
                    contentLvl1.removeClass("d-js-lvl2--expanded");
                    contentLvl1.addClass("d-js-lvl2--contract");
                    setTimeout(function () {
                        contentLvl1.removeClass("d-js-lvl2--contract");
                    }, 550);
                }
                toggleMenu($(this), content, 'open', 'closing', false);
            }
        });

        // $(".d-js-header__toggle-lvl-2").hover(function(){
        //     if(exceedsMaximumResolution(1264)) {
        //         if($(this).attr('aria-expanded') === 'false') {
        //             $(this).trigger('click');
        //         }
        //     }
        // }, function(){});
        $(".d-o-header__dropdown-lvl-2-prev").click(function(e){
            e.preventDefault();
            $element = $(this).parents(".d-o-header__carousel-li").find(".d-o-header__toggle-lvl-2");
            $element.trigger("click");
            $('.d-o-header__desktop-menu').css("overflow", 'overlay');
        })








    }
     //Controla todas las interacciones del dropdown de nivel 3
    function dropdownsLvl3() {
        $(".d-js-header__lvl3").click(function(){
            var content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-3");
            let allDrops = $(this).parents("ul").eq(0);
            if(!exceedsMaximumResolution(1264)) {
                content.slideToggle(600);
                $(this).attr("aria-expanded", function (index, attr) {
                    return attr == "true" ? "false" : "true";
                });
                if ($(this).attr("aria-expanded") == "true") {
                    $(this).addClass(`${window.prefixClass.js}--active`);
                } else {
                    $(this).removeClass(`${window.prefixClass.js}--active`);
                }
                allDrops.find(`.d-js-header__lvl3`).not(this).each(function () {
                    if ($(this).attr("aria-expanded") == "true") {
                        let content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-3");
                        content.slideUp(600);
                        $(this).attr("aria-expanded", "false");
                        $(this).removeClass(`${window.prefixClass.js}--active`);
                    }
                });
            } else {
                if (content.is(':visible')) {
                    content.animate({ opacity: 0 }, 600, function() {
                        content.css('display', 'none');
                    });
                } else {
                    content.css({ display: 'block', opacity: 0 });
                    content.animate({ opacity: 1 }, 600);
                }
                $(this).attr("aria-expanded", function (index, attr) {
                    return attr === "true" ? "false" : "true";
                });
                if ($(this).attr("aria-expanded") === "true") {
                    $(this).addClass(`${window.prefixClass.js}--active`);
                } else {
                    $(this).removeClass(`${window.prefixClass.js}--active`);
                }
                allDrops.find(`.d-js-header__lvl3`).not(this).each(function () {
                    if ($(this).attr("aria-expanded") === "true") {
                        let content = $(this).parents("li").eq(0).find(".d-o-header__dropdown-lvl-3");
                        content.animate({ opacity: 0 }, 400, function() {
                            content.css('display', 'none');
                        });
                        $(this).attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
                    }
                });
            }
        });
        // $(".d-js-header__lvl3").hover(function(){
        //     if(exceedsMaximumResolution(1264)) {
        //         if($(this).attr('aria-expanded') === 'false') {
        //             $(this).trigger('click');
        //         }
        //     }
        // }, function(){});
    }
    function closeAlldropdownsLvl3() {
        $(".d-js-header__lvl3").each(function(){
            if($(this).attr('aria-expanded') == 'true'){
                $(this).trigger('click')
            }
        })
    }
    //Genera el carrusel de nivel 2 en desktop
    function carrouselMenu() {
        function quitCarousel() {
            $(".d-o-dropdown").find('.d-c-header__carousel-wrapper').each(function(){
                var $wrapper = $(this);
                var $carousel = $wrapper.find('.d-js-header__carousel');
                var $ul = $carousel.find('.d-o-header__carousel-ul');
                $ul.attr("style", "");
                $wrapper.find('.d-c-header__carousel-control.next').addClass('d-none');
                $wrapper.find('.d-c-header__carousel-control.prev').addClass('d-none');
                $carousel.find(".d-o-header__dropdown-lvl-2-container").attr("style", "");
            });
        }
        $(".d-js-header__toggle-carousel").one("click", function(){
            if(exceedsMaximumResolution(1264)) {
                $(this).parents(".d-o-dropdown").find('.d-c-header__carousel-wrapper').each(function() {
                    var $wrapper = $(this);
                    var $carousel = $wrapper.find('.d-js-header__carousel');
                    var $ul = $carousel.find('.d-o-header__carousel-ul');
                    var $items = $ul.find('.d-o-header__carousel-li');
                    let itemWidths = [];
                    var itemsTotalWidths = 0;
                    var offsetArray = []
                    var currentIndex = 0;
                    var offsetGeneral = 0; 
                    var maxIndex = 0;
                    var minIndex = 0;
                    setTimeout(function(){
                        currentIndex = indexInitial();
                        minIndex = currentIndex;
                        itemsTotalWidths = maxSize();
                        maxIndex = calcMaxIndex();
                        if(needCarousel(itemsTotalWidths)) {
                            initialize();
                            resizeComponent(function() {
                                if(exceedsMaximumResolution(1264)) {
                                    updateItemWidths();
                                    initialize();
                                }
                            });
                        }
                    }, 80);
                    function needCarousel(size) {
                        if(size > 1136) {
                            return true
                        } else {
                            return false
                        }
                    }
                    function maxSize() {
                        var itemsVisible = 0;
                        $items.map(function(index) {
                            itemsVisible = $(this).outerWidth(true) + 16 + itemsVisible;
                        });
                        return itemsVisible;
                    }
                    function calcMaxIndex () {
                        return $items.length - 1;
                    }
                    function updateItemWidths() {
                        itemWidths = $items.map(function() {
                            return $(this).outerWidth(true) + 16; // Incluye gap
                        }).get();
                    }
                    function updateDropdownsLvl2(valTranslate) {
                        $carousel.find(".d-o-header__dropdown-lvl-2-container").css('transform', valTranslate);
                    }
                    function indexInitial() {
                        var itemsVisible = 0;
                        var indexActual = -1;
                        $items.map(function(index) {
                            if(itemsVisible < window.layout.containerDesktop) {
                                itemsVisible = $(this).outerWidth(true) + 16 + itemsVisible;
                                offsetArray.push(0);
                                indexActual++;
                            }
                        });
                        offsetArray.shift();
                        return indexActual - 1;
                    }
                    function sizeElements(inicial, final) {
                        let itemsVisible = 0;
                        $items.map(function(index) {
                            if(index >= inicial && index <= final){
                                itemsVisible = $(this).outerWidth(true) + 16 + itemsVisible;
                            }
                        });
                        return itemsVisible;
                    }
                    function updateCarousel() {
                        let container = window.layout.containerDesktop;
                        if(offsetGeneral == 0 && offsetArray[currentIndex] == 0) {
                            let sizeActual = sizeElements(0, currentIndex+1);
                            let offsetNow = sizeActual - window.layout.containerDesktop;
                            offsetArray.push(offsetNow);
                            $ul.css('transform', `translateX(0px)`);
                            updateDropdownsLvl2(`translateX(0px)`);
                            if(offsetArray[currentIndex] == 0) {
                                $wrapper.find('.d-c-header__carousel-control.prev').addClass("d-none");
                            }
                        } else {
                            if(currentIndex <= maxIndex) {
                                $ul.css('transform', `translateX(-${offsetArray[currentIndex]}px)`);
                                updateDropdownsLvl2(`translateX(${offsetArray[currentIndex]}px)`);
                                let offsetNow = offsetArray[currentIndex] + itemWidths[currentIndex+1];
                                offsetArray.push(offsetNow);
                                $wrapper.find('.d-c-header__carousel-control.prev').removeClass("d-none");
                            }
                        }
                    }
                    function showNextItem() {
                        if (currentIndex < maxIndex) {
                            currentIndex++;
                            updateCarousel();
                        }
                        if(currentIndex == maxIndex) {
                            $wrapper.find('.d-c-header__carousel-control.next').addClass("d-none");
                        }
                    }
                    function showPrevItem() {
                        if (currentIndex > minIndex) {
                            currentIndex--;
                            updateCarousel();
                            $wrapper.find('.d-c-header__carousel-control.next').removeClass("d-none");
                        }
                        if (!(currentIndex > minIndex)) {
                            $wrapper.find('.d-c-header__carousel-control.prev').addClass("d-none");
                        }
                    }
                    function tabNavigation () {
                        var tabPressed = false;
                        var prevTab = false;
                        $wrapper.find('.d-t-header__lvl2').on('keydown', function(event) {
                            if (event.key === 'Tab' || event.keyCode === 9) {
                                if (event.shiftKey) {
                                    prevTab = true;
                                } else {
                                    prevTab = false;
                                }
                                tabPressed = true;
                            }
                        });
                        $wrapper.find('.d-t-header__lvl2').on('focus', function() {
                            if (tabPressed) {  
                                let index =  $wrapper.find('.d-t-header__lvl2').index(this)
                                if(index >= minIndex) {
                                    if(!prevTab) {
                                        $wrapper.find('.d-c-header__carousel-control.next').trigger('click')
                                    } else {
                                        $wrapper.find('.d-c-header__carousel-control.prev').trigger('click')
                                    }
                                } else {
                                    currentIndex = minIndex;
                                }
                            }
                            tabPressed = false;
                            prevTab = false;
                        });
                        
                    }
                    function initialize() {
                        $wrapper.find('.d-c-header__carousel-control.next').click(showNextItem);
                        $wrapper.find('.d-c-header__carousel-control.prev').click(showPrevItem);
                        $wrapper.find('.d-c-header__carousel-control.next').removeClass('d-none');
                        setTimeout(function(){
                            updateItemWidths();
                            if(itemWidths.reduce((total, width) => total + width, 0) < 1136) {
                                $ul.width(1136);
                            } else {
                                $ul.width(itemWidths.reduce((total, width) => total + width, 0));
                            }
                            updateCarousel();
                            tabNavigation();
                        }, 100);
                    }
                });   
            }
        });
        resizeComponent(function(){
            if(!exceedsMaximumResolution(1264)) {
                quitCarousel();
            }
        });
    }
    //Cierra todos los dropdowns de level 2
    function closeAllDropdownslvl2() {
        $(".d-js-header__toggle-lvl-2").each(function(){
            if ($(this).attr("aria-expanded") == "true") {
                $(this).removeClass(`${window.prefixClass.js}--active`);
                let $content = $(this).parents(`.d-o-header__carousel-li`).find(`.d-o-header__dropdown-lvl-2`);
                toggleMenu($(this), $content, 'open', 'closing', false);
            }
        });
    }
    //Cierra un dropdown especifico del level 2
    function closeMenuDropdownslvl2($principal) {
        $principal.find(".d-js-header__toggle-lvl-2").each(function(){
            if ($(this).attr("aria-expanded") == "true") {
                $(this).removeClass(`${window.prefixClass.js}--active`);
                let $content = $(this).parents(`.d-o-header__carousel-li`).find(`.d-o-header__dropdown-lvl-2`);
                toggleMenu($(this), $content, 'open', 'closing', false);
            }
        });
    }
    function closeMenuDropdownslvl2NotAnimation($principal) {
        $principal.find(".d-js-header__toggle-lvl-2").each(function(){
            if ($(this).attr("aria-expanded") == "true") {
                $(this).removeClass(`${window.prefixClass.js}--active`);
                let $content = $(this).parents(`.d-o-header__carousel-li`).find(`.d-o-header__dropdown-lvl-2`);
                $content.css('display', 'none                                       ')
                $(this).attr("aria-expanded", 'false')
            }
        });
    }
    //Cirra los dropdowns de level 1
    function closeMenuDropdowns() {
        var nameObject = 'dropdown';
        var object = window.prefixClass.object + "-" + nameObject;
        var objectJS = window.prefixClass.js + "-" + nameObject;
        $(".d-js-header__toggle-carousel").each(function(){
            if ($(this).attr("aria-expanded") == "true") {
                let $content = $(this).parents(`.${object}`).find(`.${objectJS}__content`);
                $(this).removeClass("d-js--active");
                $content.removeClass("d-js-lvl2--expanded")
                toggleMenu($(this), $content, 'open', 'closing', false);
            }

        });
    }
    //Abre y cierra el buscador en desktop y tablet
    function searchHeader() {
        $('.d-o-header__search-toggle:not(.d-t-search--active)').click(function(e){
            e.preventDefault();
            var $content = $(".d-o-header__tablet-search");
            if ($(this).attr("aria-expanded") == "false") {
                closeMenuDropdowns();
            }
            toggleMenu($(this), $content, 'open', 'closing', true);
        });
        $(".d-c-search-bar__btn-submit").click(function(){
            var $content = $(".d-o-header__tablet-search");
            if(!$content.hasClass("d-t-search--active")) {
                $('.d-o-header__search-toggle').trigger("click");
            }
        })
    }
    //Se encarga de que solo haya un dropdown activo entre el preheader, header y search
    function interactionPreHeaderAndSearch() {
        function closeDrops() {
            if(exceedsMaximumResolution(1264)) {
                $('.d-js-header__toggle-carousel').each(function(){
                    var $button = $(this);
                    var isExpanded = $button.attr('aria-expanded') === 'true';
                    if(isExpanded) {
                        $button.trigger('click');
                    }
                });
            }
        }
        function closeThisSearch() {
            if(exceedsMaximumResolution(1264)) {
                if($('.d-o-header__search-toggle').attr('aria-expanded') == 'true') {
                    $('.d-o-header__search-toggle').trigger("click");
                }
            }
        }
        function closeDropsAndSearch() {
            closeDrops();
            closeThisSearch();
        }
        // $('.d-o-header__preheader .d-c-preheader-btn-group_container .d-t-dropdown__btn-preheader').hover(closeDropsAndSearch, function(){});
        // $('.d-o-header__preheader .d-c-preheader__accessibility a').hover(closeDrops, function(){});
        // $('.d-o-header__preheader .d-c-preheader__accessibility button').hover(closeDrops, function(){});
        // $('.d-o-header__preheader .d-c-preheader_site').hover(closeDrops, function(){});

        $('.d-o-header__preheader .d-c-preheader-btn-group_container .d-t-dropdown__btn-preheader').on('click', closeDropsAndSearch);
        $('.d-o-header__preheader .d-c-preheader__accessibility a').on('click', closeDrops);
        $('.d-o-header__preheader .d-c-preheader__accessibility button').on('click', closeDrops);
        $('.d-o-header__preheader .d-c-preheader_site').on('click', closeDrops);


    }
