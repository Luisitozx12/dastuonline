     */
       let index = 0; // Valor inicial
       const $items = $('.item-focuseable'); // Todos los ítems del carrusel
       const itemWidth = $items.first().outerWidth(); // Ancho de un ítem
       let isPartialMoved = false; // Estado para controlar si ya hemos movido un ítem parcial
       lastItem = null;
       
       // Paso 1: Detectar el siguiente índice visible
       // Función para obtener el siguiente índice visible
    function getNextVisibleIndex(currentIndex, direction = 'right') {
        console.log("Índice actual:", currentIndex); // Log del índice actual

        // Si currentIndex es null o undefined, lo seteamos a 0
        if (currentIndex == null) {
            currentIndex = 0;
        }

        // Bucle para verificar los ítems a partir del índice actual
        for (let i = currentIndex; i < $items.length; i++) {
            const $item = $($items[i]);

            // Verificamos si el ítem existe en el DOM antes de intentar acceder a su propiedad
            if ($item.length === 0) {
                continue; // Si el ítem no existe, saltamos al siguiente
            }

            const itemRect = $item[0].getBoundingClientRect();
            const contenedor = $('#d-js-preheader-btn-group')[0];  // Usamos contenedor
            const contenedorRect = contenedor.getBoundingClientRect();

            console.log(`Coordenadas del ítem ${i}:`, itemRect);
            console.log(`Coordenadas del contenedor:`, contenedorRect);

            // Verificamos si el ítem está completamente visible
            if (direction === 'right') {
                // Si estamos moviendo a la derecha, el ítem debe estar completamente dentro del contenedor
                if (itemRect.left >= contenedorRect.left && itemRect.right <= contenedorRect.right) {
                    console.log(`Ítem ${i} completamente visible`);
                } else {
                    console.log(`Ítem parcialmente visible: Índice ${i}`);
                    return i; // Devuelve el índice del primer ítem parcialmente visible
                }
            } else {
                // Si estamos moviendo a la izquierda, el ítem debe estar completamente dentro del contenedor
                if (itemRect.right <= contenedorRect.right && itemRect.left >= contenedorRect.left) {
                    console.log(`Ítem ${i} completamente visible`);
                } else {
                    console.log(`Ítem parcialmente visible: Índice ${i}`);
                    return i; // Devuelve el índice del primer ítem parcialmente visible
                }
            }
        }

        return currentIndex; // Si todos están completamente visibles, regresa el índice actual
    }

       
       // Paso 2: Desplazar el carrusel a la derecha
    
       let isFirstMoveRight = true; // Flag para saber si es el primer movimiento a la derecha


        function moveCarouselRight() {
            const contenedor = $('#d-js-preheader-btn-group');  // Usamos contenedor
            let nextIndex = 0;  // Empezamos siempre desde el primer ítem

            // Paso 1: Revisamos si es el primer movimiento hacia la derecha
            if (isFirstMoveRight) {
                console.log("reiniciando parcialidad")
                let isPartialMoved = false; // Indicador de si se ha movido un ítem parcialmente

                // Buscamos si hay algún ítem parcialmente visible
                for (let i = 0; i < $items.length; i++) {
                    console.log(i)
                    let $item = $($items[i]);
                    const itemRect = $item[0].getBoundingClientRect();
                    const containerRect = contenedor[0].getBoundingClientRect();  // Accede al DOM real con [0]
                
                    // Log para ver los valores de itemRect y containerRect
                    console.log(`Ítem en el índice ${i}`);
                    console.log(`itemRect.left: ${itemRect.left}`);
                    console.log(`itemRect.right: ${itemRect.right}`);
                    console.log(`containerRect.left: ${containerRect.left}`);
                    console.log(`containerRect.right: ${containerRect.right}`);
                
                    // Verificamos si el ítem está parcialmente visible (es decir, solo una parte de él está visible)
                    if (itemRect.left < containerRect.right && itemRect.right > containerRect.right) {
                        console.log(`Ítem parcialmente visible encontrado en el índice: ${i}`);
                
                        // Corregimos el cálculo del desplazamiento
                        let shiftAmount = itemRect.right - containerRect.right;  // Desplazamiento desde el borde derecho del ítem hasta el contenedor
                        console.log(`Desplazamiento necesario para el ítem parcialmente visible a la derecha: ${shiftAmount}`);
                
                        let currentScroll = contenedor.scrollLeft();
                        let newScroll = currentScroll + shiftAmount;
                        let maxScroll = contenedor[0].scrollWidth - contenedor.outerWidth();
                        newScroll = Math.max(0, Math.min(newScroll, maxScroll));
                
                        console.log(`Desplazamiento calculado al right: ${shiftAmount}`);
                        contenedor[0].classList.add('animate-scroll-right');
                        contenedor.stop(true, true).scrollLeft(newScroll);
                
                        // Eliminar la clase después de un tiempo para que pueda aplicarse nuevamente en el siguiente movimiento
                        setTimeout(() => {
                            contenedor[0].classList.remove('animate-scroll-right');
                        }, 300);  // Duración de la animación (500ms en este caso)
                
                        isPartialMoved = true; // Marcamos que se movió un ítem parcialmente
                        index = i;  // Actualizamos el índice con el índice del ítem parcialmente visible
                        //break;  // Salimos del ciclo una vez que encontramos el ítem parcialmente visible
                    } else {
                        console.log(`Ítem en el índice ${i} no es parcialmente visible.`);
                    }
                }
                


                // Paso 2: Si no se ha movido un ítem parcialmente visible, movemos el carrusel al siguiente ítem completo
                if (!isPartialMoved) {
                    let containerWidth = contenedor.outerWidth() - 10; // Restamos 7 píxeles al ancho del contenedor

                    // Buscar el primer ítem completamente fuera de la vista a la derecha del contenedor
                    let firstHiddenIndex = -1;
                    for (let i = 0; i < $items.length; i++) {
                        const $item = $($items[i]);
                        const itemRect = $item[0].getBoundingClientRect();
                        const carouselRect = contenedor[0].getBoundingClientRect();

                        // Si el ítem está completamente fuera de la vista a la derecha
                        if (itemRect.left >= carouselRect.right) {
                            firstHiddenIndex = i;
                            break;
                        }
                    }

                    if (firstHiddenIndex !== -1) {
                        const itemToMoveIndex = firstHiddenIndex; // Ajustamos el índice para mover el carrusel al ítem anterior
                        const $itemToMove = $($items[itemToMoveIndex]);
                        const itemToMoveWidth = $itemToMove.outerWidth(); // Obtener el ancho del ítem a mover
                        

                        let currentScroll = contenedor.scrollLeft();
                        let newScroll = currentScroll + itemToMoveWidth;
                        let maxScroll = contenedor[0].scrollWidth - containerWidth;
                        newScroll = Math.max(0, Math.min(newScroll, maxScroll));

                       

                        contenedor[0].classList.add('animate-scroll-right');
                        contenedor.stop(true, true).scrollLeft(newScroll);
                
                        // Eliminar la clase después de un tiempo para que pueda aplicarse nuevamente en el siguiente movimiento
                        setTimeout(() => {
                            contenedor[0].classList.remove('animate-scroll-right');
                        }, 300);  // Duración de la animación (500ms en este caso)

                        index = itemToMoveIndex + 1; // Actualizamos el índice
                    }
                }

                // Después del primer movimiento, desactivamos la flag de primer movimiento
                isFirstMoveRight = false;

            } else {
                console.log("click consecutivo")
                let containerWidth = contenedor.outerWidth() - 7; // Restamos 7 píxeles al ancho del contenedor

                    // Buscar el primer ítem completamente fuera de la vista a la derecha del contenedor
                    let firstHiddenIndex = -1;
                    for (let i = 0; i < $items.length; i++) {
                        const $item = $($items[i]);
                        const itemRect = $item[0].getBoundingClientRect();
                        const carouselRect = contenedor[0].getBoundingClientRect();

                        // Si el ítem está completamente fuera de la vista a la derecha
                        if (itemRect.left >= carouselRect.right) {
                            firstHiddenIndex = i;
                            console.log(`primer indice oculto ${i}`)
                            break;
                        }
                    }

                    if (firstHiddenIndex !== -1) {
                        const itemToMoveIndex = firstHiddenIndex;
                        const $itemToMove = $($items[itemToMoveIndex]);
                  
            
                        // Calculamos el ancho correcto del ítem seleccionado
                        const itemToMoveWidth = $itemToMove.outerWidth();  // Obtener el ancho del ítem a mover
            
                        console.log("Ítem a mover: ", $itemToMove[0]); // Muestra el elemento que se está moviendo
                        console.log("Ítem a mover  ultimo ultimo (Índice): ", itemToMoveIndex); // Muestra el índice del ítem
                      
                        let currentScroll = contenedor.scrollLeft();
                        let newScroll = currentScroll + itemToMoveWidth;
                        let maxScroll = contenedor[0].scrollWidth - containerWidth;
                        newScroll = Math.max(0, Math.min(newScroll, maxScroll));

                        if (itemToMoveIndex === $items.length - 1) {
                            console.log("Último ítem alcanzado, moviendo al maxScroll");
                            newScroll = maxScroll;  // Establecemos el scroll directamente al maxScroll
                        }
        



                        contenedor[0].classList.add('animate-scroll-right');
                        contenedor.stop(true, true).scrollLeft(newScroll);
                
                        // Eliminar la clase después de un tiempo para que pueda aplicarse nuevamente en el siguiente movimiento
                        setTimeout(() => {
                            contenedor[0].classList.remove('animate-scroll-right');
                        }, 300);  // Duración de la animación (500ms en este caso)

                        index = itemToMoveIndex + 1; // Actualizamos el índice

                     
                    }
            }

            // Comprobamos si estamos en el último desplazamiento
            const maxScroll = contenedor[0].scrollWidth - contenedor.outerWidth();
            let currentScroll = contenedor.scrollLeft();
            console.log("currentscroll por martha:", currentScroll);
            console.log("maxcroll por martha:", maxScroll);
            
            if (currentScroll >= maxScroll - 1) {
                // Desplazar directamente al final del carrusel si la diferencia es 1 o menos
                console.log("Moviendo carrusel al máximo");
                contenedor.stop(true, true).scrollLeft(maxScroll);
            }

            console.log("Índice después del clic:", index); // Log del índice después del clic

            // Después de mover el carrusel, actualizamos el estado de los ítems visibles
            updateItemVisibility();
        }

       
       function moveCarouselLeft() {
           const contenedor = $('#d-js-preheader-btn-group');  // Usamos contenedor
       
           // Cuando se mueve hacia la izquierda, restablecemos el flag de primer movimiento a la derecha
           isFirstMoveRight = true; // Esto hace que el siguiente movimiento hacia la derecha sea tratado como el primer movimiento
       
           let prevIndex = lastItem !== null ? lastItem : index;  // Comienza desde lastItem
           console.log("Índice de inicio para retroceder:", prevIndex);
       
           let isPartial = false; // Indicador para saber si encontramos un ítem parcial
           let isPartialMoved = false;  // Indicador de si se ha movido un ítem parcial
       
           // Iteramos hacia atrás para encontrar el primer ítem parcial visible
           for (let i = prevIndex; i >= 0; i--) {
               let isPartial = checkIfItemIsPartialII(i, 'left');  // Verificar si el ítem es parcial
               console.log("Ítem parcialmente visible en retroceso:", isPartial); // Log si el ítem es parcial o no
       
               if (isPartial) {
                   // Si encontramos un ítem parcialmente visible, movemos el carrusel para hacerlo visible completamente
                   let $item = $($items[i]);
                   let itemRect = $item[0].getBoundingClientRect();  // Obtener el rectángulo del ítem
                   let containerRect = contenedor[0].getBoundingClientRect();  // Obtener el rectángulo del contenedor
       
                   // Calcular el desplazamiento necesario para que el ítem sea completamente visible
                   let shiftAmount = -(itemRect.left - containerRect.left);
                   console.log(`Desplazamiento necesario para el ítem ${i}: ${shiftAmount} píxeles a la izquierda`);
       
                   let currentScroll = contenedor.scrollLeft();
                   let newScroll = currentScroll - shiftAmount; // Movemos hacia la izquierda
                   let containerWidth = contenedor.outerWidth() - 7; // Restamos 7 píxeles al ancho del contenedor
                   let maxScroll = contenedor[0].scrollWidth - containerWidth;
                   newScroll = Math.max(0, Math.min(newScroll, maxScroll));
       
                   console.log(`Desplazamiento calculado al left: ${shiftAmount}`);
          


                contenedor[0].classList.add('animate-scroll-left');
                contenedor.stop(true, true).scrollLeft(newScroll);
        
                // Eliminar la clase después de un tiempo para que pueda aplicarse nuevamente en el siguiente movimiento
                setTimeout(() => {
                    contenedor[0].classList.remove('animate-scroll-left');
                }, 300);  // Duración de la animación (500ms en este caso)



                   isPartialMoved = true;  // Marca que se movió un ítem parcialmente visible
                   break;  // Salir del bucle una vez que se ha movido un ítem parcial
               }
           }
       
           // Solo si NO se ha movido un ítem parcial, proceder con los ítems completos
           if (!isPartialMoved) {
               // Buscar el primer ítem completamente visible a la izquierda
               let firstHiddenIndex = -1;
               for (let i = prevIndex - 1; i >= 0; i--) {
                   const $item = $($items[i]);
                   const itemRect = $item[0].getBoundingClientRect();
                   const carouselRect = contenedor[0].getBoundingClientRect();
       
                   // Si el ítem está completamente fuera de la vista a la izquierda
                   if (itemRect.right <= carouselRect.left) {
                       firstHiddenIndex = i;
                       break;
                   }
               }
       
               if (firstHiddenIndex !== -1) {
                   // Mover el carrusel por el siguiente ítem completo
                   const $itemToMove = $($items[firstHiddenIndex]);
                   const itemToMoveWidth = $itemToMove.outerWidth();  // Obtener el ancho del ítem a mover
       
                   let currentScroll = contenedor.scrollLeft();
                   let newScroll = currentScroll - itemToMoveWidth;  // Mover hacia la izquierda
                   let containerWidth = contenedor.outerWidth() - 7;  // Restamos 7 píxeles al ancho del contenedor
                   let maxScroll = contenedor[0].scrollWidth - containerWidth;
                   newScroll = Math.max(0, Math.min(newScroll, maxScroll));
       
                   console.log(`Desplazamiento calculado left completo: ${itemToMoveWidth}`);
                   
                contenedor[0].classList.add('animate-scroll-left');
                contenedor.stop(true, true).scrollLeft(newScroll);
        
                // Eliminar la clase después de un tiempo para que pueda aplicarse nuevamente en el siguiente movimiento
                setTimeout(() => {
                    contenedor[0].classList.remove('animate-scroll-left');
                }, 300);  // Duración de la animación (500ms en este caso)
               }
       
               isPartialMoved = false;  // No se movió un ítem parcial
               index--;
               isLastItem = index
           }
       
           // Actualizar el estado final del índice después del movimiento
           lastItem = prevIndex;
           console.log("Índice después del clic (retrocediendo):", lastItem);
       
           // Después de mover el carrusel, actualizamos el índice solo si el ítem fue completamente visible
           if (!isPartialMoved) {
               index = prevIndex;  // Actualizamos el índice solo si ya no hay ítems parciales
           }
       
           // Después de mover el carrusel, actualizamos el estado de los ítems visibles
           updateItemVisibility();
       }
           
       // Paso 4: Verificar si un ítem está parcialmente visible
       function calculatePartialShift(itemIndex, direction = 'right') {
        const $item = $($items[itemIndex]);
    
        // Verificamos si el ítem existe en el DOM antes de intentar acceder a su propiedad
        if ($item.length === 0) {
            return 0; // Si el ítem no existe, no hay desplazamiento
        }
    
        // Obtener las coordenadas del ítem
        const itemRect = $item[0].getBoundingClientRect();
        console.log('Coordenadas del ítem:', itemRect);
    
        // Obtener las coordenadas del contenedor
        const contenedor = $('#d-js-preheader-btn-group')[0];  // Usamos contenedor
        console.log('Coordenadas del contenedor:', contenedor.getBoundingClientRect());
    
        // Obtener el ancho del contenedor y restar 7 píxeles
        const containerWidth = contenedor.getBoundingClientRect().width - 7;
        console.log('Ancho del contenedor ajustado:', containerWidth);
    
        // Variable para el espacio ocupado
        let spaceOccupied = 0;
    
        if (direction === 'right') {
            // Si nos movemos hacia la derecha, sumar el espacio ocupado por los ítems anteriores
            for (let i = 0; i < itemIndex; i++) {
                const $prevItem = $($items[i]);
                if ($prevItem.length > 0) {
                    spaceOccupied += $prevItem.outerWidth(); // Sumar el ancho de cada ítem visible
                }
            }
        } else {
            // Si nos movemos hacia la izquierda, sumar el espacio ocupado por los ítems posteriores
            for (let i = itemIndex + 1; i < $items.length; i++) {
                const $nextItem = $($items[i]);
                if ($nextItem.length > 0) {
                    spaceOccupied += $nextItem.outerWidth(); // Sumar el ancho de cada ítem visible
                }
            }
        }
    
        // Calcular cuánto espacio queda disponible en el contenedor
        const remainingSpace = containerWidth - spaceOccupied;
        console.log('Espacio restante en el contenedor:', remainingSpace);
    
        // Calcular el desplazamiento necesario para que el ítem sea completamente visible
        const shiftAmount = itemRect.width - remainingSpace;
        console.log("Desplazamiento necesario para visibilidad completa (pixeles):", shiftAmount);
    
        // Devolver el valor del desplazamiento, si es negativo (es decir, ya está completamente visible), devolvemos 0
        return shiftAmount > 0 ? shiftAmount : 0;
    }
              
       // Función para verificar si un ítem está parcialmente visible
       function checkIfItemIsPartial(itemIndex, direction = 'right') {
           const $item = $($items[itemIndex]);
       
           // Verificamos si el ítem existe en el DOM antes de intentar acceder a su propiedad
           if ($item.length === 0) {
               return false; // Si el ítem no existe, no está parcialmente visible
           }
       
           const itemRect = $item[0].getBoundingClientRect();
           const contenedor = $('#d-js-preheader-btn-group')[0];  // Usamos contenedor
       
           // Si estamos moviendo a la derecha, solo verificamos los ítems a la derecha
           if (direction === 'right') {
               return itemRect.left < contenedor.getBoundingClientRect().right && itemRect.right > contenedor.getBoundingClientRect().right;
           }
           // Si estamos moviendo a la izquierda, verificamos si el ítem está parcialmente visible a la izquierda
           else {
               return itemRect.left < contenedor.getBoundingClientRect().left && itemRect.right > contenedor.getBoundingClientRect().left;
           }
       }

       function checkIfItemIsPartialII(index, direction = 'left') {
        const $item = $($items[index]);
    
        // Verificamos si el ítem existe en el DOM antes de intentar acceder a su propiedad
        if ($item.length === 0) {
            return false; // Si el ítem no existe, no está parcialmente visible
        }
    
        const itemRect = $item[0].getBoundingClientRect();
        const contenedor = $('#d-js-preheader-btn-group')[0];  // Usamos contenedor
    
        // Solo verificamos los ítems cuando se mueve hacia la izquierda
    if (direction === 'left') {
        // Revisamos si el ítem está parcialmente visible hacia la izquierda
        return itemRect.right > contenedor.getBoundingClientRect().left && itemRect.left < contenedor.getBoundingClientRect().left;
    }
        // Si la dirección no es 'left', simplemente devolvemos false (no revisamos hacia adelante)
        return false;
    }
             
       // Función que actualiza la visibilidad de los ítems
       function updateItemVisibility() {
           const contenedor = $('#d-js-preheader-btn-group'); // Contenedor del carrusel
       
           // Aseguramos que cada ítem esté correctamente marcado como visible o no visible
           $items.each(function (index, item) {
               const $item = $(item);
               const itemRect = item.getBoundingClientRect();
               const contenedorRect = contenedor[0].getBoundingClientRect();
       
               if (itemRect.left >= contenedorRect.left && itemRect.right <= contenedorRect.right) {
                   console.log(`Ítem ${index} completamente visible`);
               } else if (itemRect.left < contenedorRect.right && itemRect.right > contenedorRect.left) {
                   console.log(`Ítem ${index} parcialmente visible`);
               } else {
                   console.log(`Ítem ${index} no visible`);
               }
           });
       }
          
