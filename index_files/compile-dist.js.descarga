        //determinar la visibilidad de los items, si estan parcialmente cubiertos
        function updateItemVisibility() {
            if ($container.length === 0 || $scrollLeft.length === 0 || $scrollRight.length === 0) return;
            const scrollLeftRect = $scrollLeft[0].getBoundingClientRect();
            const scrollRightRect = $scrollRight[0].getBoundingClientRect();
        
            $container.find('.d-c-preheader-item').each(function() {
                const $item = $(this);
                const itemRect = $item[0].getBoundingClientRect();
                const intersectionLeft = Math.max(0, Math.min(itemRect.right, scrollLeftRect.right) - Math.max(itemRect.left, scrollLeftRect.left));
                const intersectionRight = Math.max(0, Math.min(itemRect.right, scrollRightRect.right) - Math.max(itemRect.left, scrollRightRect.left));
        
                const itemArea = (itemRect.right - itemRect.left) * (itemRect.bottom - itemRect.top);
                const intersectionAreaLeft = (intersectionLeft > 0) ? intersectionLeft * Math.min(itemRect.bottom - itemRect.top, scrollLeftRect.bottom - scrollLeftRect.top) : 0;
                const intersectionAreaRight = (intersectionRight > 0) ? intersectionRight * Math.min(itemRect.bottom - itemRect.top, scrollRightRect.bottom - scrollRightRect.top) : 0;
                const coverageThreshold = 0.4; 

                const isPartiallyCoveredByLeft = (intersectionAreaLeft / itemArea) >= coverageThreshold;
                const isPartiallyCoveredByRight = (intersectionAreaRight / itemArea) >= coverageThreshold;
        
                if (isPartiallyCoveredByLeft || isPartiallyCoveredByRight) {
                    $item.addClass('disabled');
                } else {
                    $item.removeClass('disabled');
                }
            });
        }
    
        // Inicializa el estado de los botones y la visibilidad de los ítems
        updateButtonStates();
        updateItemVisibility();
    
        // Eventos para los botones de desplazamiento
        $scrollRight.click(function() {
            //scrollToDirection('right');
            moveCarouselRight();
        });
    
        $scrollLeft.click(function() {
            //scrollToDirection('left');
            moveCarouselLeft();
        });
    
        // Actualiza el estado de los botones y la visibilidad de los ítems en el desplazamiento del carrusel
        $container.on('scroll', function() {
            updateButtonStates();
            updateItemVisibility();
        });
  
        $('.d-t-dropdown__btn').on('click', function(event) {
            event.preventDefault();
            var $container = $(this).siblings('.d-t-dropdown__container');
            if ($container.hasClass('active')) {
                $container.removeClass('active');
            } else {
                $('.d-t-dropdown__container').removeClass('active');
                $container.addClass('active');
            }
        });

        //otras funciones
        $('.d-c-preheader').find('.item').each(function() {
            if ($(this).find('.d-t-dropdown__btn').length === 0) {
              $(this).addClass('no-dropdown-btn');
            } else {
              $(this).addClass('has-dropdown-btn');
            }
          });


          $('.d-c-preheader').find('.d-c-preheader-item').each(function() {
            if ($(this).find('.d-t-dropdown__btn').length === 0) {
              $(this).addClass('no-dropdown-btn-preheader-item');
            } else {
              $(this).addClass('has-dropdown-btn-preheader-item');
            }
          });

          //por defecto en mobile o tablet todas estan sombreadas con linea gray
          function adjustWidths() {
            var owlItemWidth = $('.owl-item').first().outerWidth();
            
            if (owlItemWidth) {
                $('.d-c-preheader-item').each(function() {
                    $(this).css('width', owlItemWidth);
                });
                $('.item').each(function() {
                    $(this).css('width', owlItemWidth);
                });
            } else {
                setTimeout(adjustWidths, 100);
            }
        }
        
        if (resolutionCurrent < 1265) {
            $('.d-c-preheader-line').addClass('d-c-preheader-gray-line');
            adjustWidths();
        }

         
//funcion para alternar press entre las sections en mobile y tablet

function dropdownSelect() {
    
    if (!exceedsMaximumResolution(1264)) {
        $('.d-c-preheader-item .d-c-preheader-line').removeClass('d-c-preheader-red-line').addClass('d-c-preheader-gray-line');
        $('.d-c-preheader-item').addClass("d-c-preheader-item-normal");        
        $(this).find('.d-c-preheader-line').removeClass('d-c-preheader-gray-line').addClass('d-c-preheader-red-line');
        $(this).addClass("d-c-preheader-item-bold");
    }
}

    $('.has-dropdown-btn-preheader-item').click(function(e) {
        if (!$('body').hasClass('has-edit-mode-menu')){
            dropdownSelect.call(this);

        }
           
            
    });
  
 

        //asignando ids dinámicos al carrusel
        function asignarIDcarruselPreheader() {
        $(".d-c-preheader").each(function (index) {
          var uniqueID = 'd-c-preheader-' + (index + 1);
              $(this).attr('id', uniqueID);
        });
      }     
      asignarIDcarruselPreheader();




        var previousHeight = null;
        function minHeightCarruselDesktop() {
            if (!window.inspectorResize) {
                $(".d-c-preheader").each(function () {
                    var carouselContainer = $(this).find(".d-c-preheader-text");
                    var heightCarousel = carouselContainer.css('font-size');                   
                    var fontSizeValue = parseFloat(heightCarousel);
  
                    
                    // Detectar cambios en la altura
                    if (previousHeight === null || heightCarousel !== previousHeight) {                                               
                        if (fontSizeValue > 20) {
                            carouselContainer.closest(".d-c-preheader").css("height", "58px");
                            carouselContainer.closest(".item").css("white-space", "normal");
                            carouselContainer.closest(".item").css("height", "");
                            $('.d-t-dropdown__content').css("overflow-y", "scroll");
                            $('.d-t-dropdown__content').css("max-height", "500px");
                            $(".slider").css("touch-action", "auto");
                            $('.d-o-controller__icon-preheader-right').css("display", "none");
                            $('.d-o-controller__icon-preheader-left').css("display", "none");
                            $scrollRight.removeClass('disabled').addClass('active');
                            $scrollLeft.removeClass('disabled').addClass('active');

                            $('.d-c-preheader__accessibility').css("min-width", "500px");
                            $(this).css("overflow-x", "auto");
                            $(this).find(".d-t-dropdown__container-box").find("span").css("line-height", "1");
                            $(this).find(".d-t-dropdown__container-box").find("a").css("line-height", "1");
                            $(this).find(".d-t-dropdown__container-box").find("a").css("line-height", "1");
                            
                            if ($(this).hasClass('d-t-preheader--new')){
                                $(this).find(".d-c-preheader-btn-group_container").css("width", "auto");
                                $(this).find(".d-c-preheader__accessibility").css("gap", "10px");
                                //$(this).find(".d-js-preheader-btn-group").css("height", "48px");
                                $(this).find(".d-c-preheader-btn-group").css("height", "58px");
                               

                            }
                            

                            
                            checkOverflow();
                        } else {         
                            //applyItemWidths();                  
                            carouselContainer.closest(".d-c-preheader").css("height", "40px");
                            carouselContainer.closest(".container").css("height", "40px");                        
                            carouselContainer.closest(".item").css("white-space", "nowrap");
                            $('.d-t-dropdown__content').css("overflow-y", "auto");
                            $('.d-t-dropdown__content').css("max-height", "2000px");
                            

                            $('.d-o-controller__icon-preheader-right').css("display", "none");
                            $('.d-o-controller__icon-preheader-left').css("display", "none");
                            $scrollRight.addClass('disabled').removeClass('active');
                            $scrollLeft.addClass('disabled').removeClass('active');
                            $(".slider").css("touch-action", "none");
                            $('.d-t-dropdown__content').removeClass("hiddeTabPreheader");
                            $('.d-t-dropdown__content').css('height', 'var(--menuPreheader-height)');
                            checkOverflow();
                            $(this).css("overflow-x", "unset");
                            if ($(this).hasClass('d-t-preheader--new')){
                                $(this).find(".d-c-preheader-btn-group_container").css("width", "100vw");
                                $(this).find(".d-c-preheader__accessibility").css("gap", "23px");
                                //$(this).find(".d-js-preheader-btn-group").css("height", "40px");
                                

                            }
                        }
                        
                        previousHeight = heightCarousel; // Actualiza la altura previa
                    }
                });
            }
        }

        function minHeightCarruselTablet() {
            if (!window.inspectorResize) {
                $(".d-c-preheader").each(function () {
                    var carouselContainer = $(this).find(".d-c-preheader-text");
                    var heightCarousel = carouselContainer.css('font-size');
                    
                    var fontSizeValue = parseFloat(heightCarousel);
                    
                    // Detectar cambios en la altura
                    if (previousHeight === null || heightCarousel !== previousHeight) {
                       
                        if (fontSizeValue > 16) {                          
                            $(".slider").css("touch-action","pan-x"); //activamos scroll con arrastre
                            
                        } else {
                          
                            carouselContainer.closest(".d-c-preheader").css("height", "40px");
                            carouselContainer.closest(".container").css("height", "40px");
                            carouselContainer.closest(".owl-item").css("white-space", "nowrap");
                            $(".slider").css("touch-action","none");//desactivamos scroll con arrastre
                        }
                        
                        previousHeight = heightCarousel; // Actualiza la altura previa
                    }
                });
            }
        }


        function minHeightCarruselMobile() {
            if (!window.inspectorResize) {
                $(".d-c-preheader").each(function () {
                    var carouselContainer = $(this).find(".d-c-preheader-text");
                    var heightCarousel = carouselContainer.css('font-size');
                    
                    var fontSizeValue = parseFloat(heightCarousel);
                    
                    // Detectar cambios en la altura
                    if (previousHeight === null || heightCarousel !== previousHeight) {
                   
                        
                        if (fontSizeValue > 14) {                       
                            $(".slider").css("touch-action","pan-x"); //activamos scroll con arrastre
                            
                        } else {                         
                            carouselContainer.closest(".d-c-preheader").css("height", "40px");
                            carouselContainer.closest(".container").css("height", "40px");
                            carouselContainer.closest(".owl-item").css("white-space", "nowrap");
                        }
                        
                        previousHeight = heightCarousel; // Actualiza la altura previa
                    }
                });
            }
        }



        
        if (window.resolutionCurrent < 768) {           
            setInterval(minHeightCarruselMobile, 3000);
        } else if (window.resolutionCurrent > 767 && window.resolutionCurrent < 1280) {
            setInterval(minHeightCarruselTablet, 3000);
        } else {
            setInterval(minHeightCarruselDesktop, 3000);
        }

  

        function manejarCambiosDeTamanio() {
            resizeComponent(function() {
                if (window.innerWidth <= 1280 && window.innerWidth >= 768) {
                    minHeightCarruselTablet();                  
                } else if  (window.innerWidth < 768){
                    minHeightCarruselMobile();                   
                }
                else {
                    minHeightCarruselDesktop();
                   
                }
            });
            
        }

        manejarCambiosDeTamanio();


        //realizamos funcion para mostrar u ocultar controladores dependiendo si se activa el carrusel
        function checkOverflow() {
            let containerWidth = $container.outerWidth();
            let totalWidth = 0;
        
            $('.d-c-preheader-item').each(function() {
                totalWidth += $(this).outerWidth(true); 
            });
        
            // Mostrar u ocultar el controlador derecho según el ancho total
            if (totalWidth > containerWidth) {
                $scrollRight.css("display", "block");
            } else {
                $scrollRight.css("display", "none");
            }
        
            // Actualizar el estado de los botones
            updateButtonStates();
        }
        
        // Inicializar y manejar el redimensionamiento
        checkOverflow();
        
        $(window).resize(function() {
            checkOverflow();
        });

        //simulamos el click en la primera tab en mobile
    function simulateClickOnFirstItem() {
        var $preheaderGroup = $('#d-js-preheader-btn-group');
        
        if ($preheaderGroup.length === 0) {
          
            return;
        }
    
        // Encuentra el primer elemento .d-c-preheader-item dentro de $preheaderGroup
        var $firstItem = $preheaderGroup.find('.d-c-preheader-item').first();
        if ($firstItem.length === 0) {

            return;
        }
    
        // Encuentra el primer enlace dentro de $firstItem
        var $btnTab = $firstItem.find('.item').first();
        if ($btnTab.length === 0) {
       
            return;
        }
    
        // Simula el clic y agrega la clase active
        $btnTab.trigger('click');
        $btnTab.addClass('active');
       
    }  

    }




    $('#scroll-left').on('click', function() {
        var $slider = $('#d-js-preheader-btn-group');
        var scrollAmount = 300; // Ajusta el valor de desplazamiento según sea necesario
        $slider.animate({ scrollLeft: $slider.scrollLeft() - scrollAmount }, 300);
     
    });

    $('#scroll-right').on('click', function() {
        var $slider = $('#d-js-preheader-btn-group');
        var scrollAmount = 300; // Ajusta el valor de desplazamiento según sea necesario
        $slider.animate({ scrollLeft: $slider.scrollLeft() + scrollAmount }, 300);
       
    });


    //funcion para ajustar el ancho de red-line 
    function adjustBorders() {
        if (!exceedsMaximumResolution(1264)) {
        
        $('.d-c-preheader-item').each(function() {
            var $this = $(this);
            var $line = $this.find('.d-c-preheader-line');
            var $btn = $this; 
            var btnWidth = $btn.outerWidth();
            $this.find('.d-c-preheader-line').css('width', btnWidth + 'px');
        });
    } else {

        $('.d-c-preheader-line').css('display', 'none');
        $('.d-c-preheader-red-line').css('display', 'none');
       
        }
      
    }

    $(window).on('resize', function() {
        this.resizeTimeout = setTimeout(function() {
            adjustBorders()
        }, 150); 
    });

  

    //quitamos borde al ultimo item del desplegable
    if (resolutionCurrent < 1265) {
        $('.d-t-dropdown__container-box').each(function() {
            const $lastItem = $(this).find('.d-t-dropdown__item').last();
            if ($lastItem.length) {
                $lastItem.css('border-bottom', 'none');
            }
        });
        $('.d-t-dropdown__content-container').each(function() {
            const $firstItem = $(this).find('.d-t-dropdown__container-title').first();
            if ($firstItem.length) {
                $firstItem.addClass('first-title');
            }
        });

        
    }

    

    // Ajusta los bordes al cargar la página
    adjustBorders();

    $(window).resize(function() {
        adjustBorders();
    });


    //ajustamos altura de los dropdown en mobile
    function adjustDropdownHeight() {
        if (!exceedsMaximumResolution(1264)) {
            const offset = 114; // El valor a restar
            const availableHeight = window.innerHeight - offset;

            // Ajusta la altura de todos los elementos deseados
            $('.d-c-preheader').find('.d-t-dropdown__content').each(function() {
                $(this).css({
                    'height': `${availableHeight}px`,
                    'max-height': `${availableHeight}px`,
                });
            });
        }
    }

    // Ajusta la altura al cargar y al redimensionar
    adjustDropdownHeight();
    $(window).resize(function() {
        adjustDropdownHeight();
    });


    if (!$('body').hasClass('has-edit-mode-menu')){
        initComponent();

    }
    
   
    $(window).on('resize', initComponent);
    resizeComponent(function(){
        if (exceedsMaximumResolution(767)) {
            $(".d-c-preheader__container").addClass("container");
            $(".d-c-preheader-btn-group_container").removeClass("container");
        } else {
            $(".d-c-preheader__container").removeClass("container");
            $(".d-c-preheader-btn-group_container").addClass("container");
        }

    



    const $container = $('#d-js-preheader-btn-group');
    if ($container.length > 0) {
        $container.scrollLeft(0);
    }
        $('.d-c-preheader-item').removeClass("disabled");
        $('.d-c-preheader-item .d-c-preheader-line').removeClass('d-c-preheader-red-line').addClass('d-c-preheader-gray-line');
       $('.d-c-preheader-item').addClass(".d-c-preheader-item-normal");

        if(resolutionCurrent<1265){
            var $preheaderGroup = $('#d-js-preheader-btn-group');
        if ($preheaderGroup.length === 0) {        
            return;
        }    
        // Encuentra el primer elemento .d-c-preheader-item dentro de $preheaderGroup
        var $firstItem = $preheaderGroup.find('.d-c-preheader-item').first();
        if ($firstItem.length === 0) {         
            return;
        }    
        // Encuentra el primer enlace dentro de $firstItem
        var $btnTab = $firstItem.find('.item').first();
        if ($btnTab.length === 0) {      
            return;
        }    
    
   
        }

        if(resolutionCurrent>1264){
            $('.d-c-preheader-line').css('display', 'none');
            $('.d-c-preheader-red-line').css('display', 'none');

        }
       
         
 
    });
}
function bannerMedium () {
    function initComponent () {

      //se realiza funcion para ajustar la alineación del texto dependiendo la resolución centrado en mobile.
      function adjustTextAlign() {    
        var resolutionCurrent = $(window).width();
        if (resolutionCurrent < 767) {
            $(".d-c-banner-medium").find('.d-c-banner-medium__title dav-text').attr('align', 'center');
            $(".d-c-banner-medium").find('.d-c-banner-medium__paragraph dav-text').attr('align', 'center');
        } 
        else {
          $(".d-c-banner-medium")
              .find('.d-c-banner-medium__title dav-text')
              .attr('align', 'left');
          $(".d-c-banner-medium")
              .find('.d-c-banner-medium__paragraph dav-text')
              .attr('align', 'left');
      }
    }
    adjustTextAlign();
   
    //realizamos función para agregar o quitar container dependiendo la resolución
    function checkWidth() {
      if (! exceedsMaximumResolution(767))  {
          $('.d-c-banner-medium_center').removeClass('container');
      } else {
          $('.d-c-banner-medium_center').addClass('container');
      }
  }

  // Ejecutamos al cargar la página
  checkWidth();
  $(window).resize(function() {
    adjustTextAlign();
    checkWidth();
    });
   
  }
    

    
    initComponent();
    
}
function bannerCentral () {
    function initComponent () {

      if ($('.d-c-banner-central').length > 0){

      $(".d-c-banner-central").each(function (index) {
        var $currentBanner = $(this);  // Referencia al banner actual
       
    
        // 1. Función para ajustar el espaciado del párrafo dependiendo si existe un botón o no.
        var paragraphExists = $currentBanner.find('.d-c-banner-central__paragraph').length > 0;
        var $btn = $currentBanner.find('.sc-dav-banner_central_button');    
    
        if (!paragraphExists) {
            $btn.addClass('largerSpace');
        } else {
            $btn.addClass('smallerSpace');
        }
    
        // 2. Ajuste adicional si no hay una imagen
        var contentImgExists = $currentBanner.find('.d-c-banner-central__content_img').length > 0;
        if (!contentImgExists) {
            //$currentBanner.find('.d-c-banner-central__title').addClass('padding-title');
            $btn.addClass('margin-btn-small');
        }
            
            
    
        // 3. Función para ajustar el tamaño de la fuente dependiendo si es desktop o no.
        function checkFontSize() {
            if (!exceedsMaximumResolution(1279)) {  // Si no es desktop (resolución menor a 1280px)
                $currentBanner.find('.d-c-banner-central__title dav-text').attr('size', '2xl');
            } else {
                $currentBanner.find('.d-c-banner-central__title dav-text').attr('size', '4xl');
            }
        }
    
        // Llamada a la función para ajustar el tamaño de la fuente
        //checkFontSize();
        if ($('.d-c-banner-central').length > 0) {
            $(".d-c-banner-central").each(function () {
                checkFontSize(); 
            });
        }
    
    });

  }

  $(window).resize(function() {
   
    if ($('.d-c-banner-central').length > 0) {
        $(".d-c-banner-central").each(function () {
            //checkFontSize(); 
        });
    }
});
     
   
  }
    

    
    initComponent();
   
}
function SearchResults () {
    function initComponent () {

      //Ocultamos contenidos que no requerimos segun diseño

        $('.d-c-search-results').find(".autofit-col").each(function() {
          if ($(this).find('.sticker-rounded').length) {
            $(this).css("display","none");
          }
        });
        $('.d-c-search-results').find(".autofit-col").each(function() {
          if ($(this).find('.sticker').length) {
            $(this).css("display","none");
          }
        });


        //eliminamos el texto que aparece antes de la categoria
        $('.d-c-search-results').find('a.asset-category').each(function() {
          let prevText = $(this).prev();
          if (prevText.length && prevText[0].nodeType === Node.TEXT_NODE) {
            prevText.remove();
          } else {
           
            let parent = $(this).parent();
            let textNodes = parent.contents().filter(function() {
              return this.nodeType === Node.TEXT_NODE;
            });
            
            textNodes.each(function() {
              if (this.textContent.trim() === $(this).text().trim()) {
                $(this).remove();
              }
            });
          }
        });

        $('.d-c-search-results').find('a.asset-category').removeClass("text-uppercase");
        $('.d-c-search-results').find('.taglib-asset-tags-summary').find(".label-secondary").removeClass("label-lg");
        $('.d-c-search-results').find('.taglib-asset-tags-summary').find(".label-secondary").removeClass("label");
        $('.d-c-search-results').find('.taglib-asset-tags-summary').find(".label-secondary").removeClass("text-uppercase");

        //afectamos al list-group cuando esta el resultado no encontrado
        $('.d-c-search-results').find('.list-group').each(function() {
          if ($(this).children('.sheet').length > 0) {
              $(this).addClass('has-sheet');
              $('.d-c-filter-searcher__categories').css("display", "none");
              $('.d-c-filter-searcher__results').css("width", "100%");  
              $('.d-c-filter-searcher__results').find(".search-total-label").css("display","none");            
          }
      });


      //para el paginador
      $(".d-c-filter-searcher__results").find(".pagination").find(".page-item").each(function() {        
        if ($(this).find('span.sr-only').length > 0) {
            $(this).addClass('has-sr-only');
        }
    });



     //aplicando estilos
    $(".d-c-filter-searcher__results").find('.autofit-col').has('.lfr-portal-tooltip').addClass('autofit-col-with-tooltip');
   
  }
    

    
    initComponent();
    
}
