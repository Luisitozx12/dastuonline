function hu06header() {
    //Se encarga de cerrar el search en tablet y desktop
    function closeSearch() {
        $(".d-o-header__search-toggle").each(function() {
            if ($(this).attr("aria-expanded") == "true") {
                $(this).attr("aria-expanded", "false");
                $('.d-o-header__tablet-search').slideUp(300);
            }
        })
    }
    //Se encarga de calcular el tamaño de los elementos en mobile
    function sizeMenuMobile() {
        function maxHeightContainerMobile() {
            if(!exceedsMaximumResolution(1264)) {
                let sizeActual = window.innerHeight;
                let sizeControls = 67;
                let sizeButton = 0;
                let sizeSearch = 0;
                let sizePreHeader = 0;
                if($('.d-o-header__collapse-footer-button dav-button').length > 0) {
                    sizeButton = $('.d-o-header__collapse-footer').outerHeight();
                } else {
                    $('.d-o-header__collapse-footer').addClass('p-0');
                }
                if($('.d-o-header__collapse-container .d-c-preheader').length > 0) {
                    sizePreHeader = $('.d-c-preheader').outerHeight();
                }
                if($('.d-o-header__collapse-container .d-c-search-bar').length > 0) {
                    sizeSearch = $('.d-o-header__search').outerHeight();
                }
                $(".d-o-header__collapse-content").css('height', `${sizeActual - sizeButton - sizeControls - sizeSearch - sizePreHeader - 15}px`);
                $('.d-o-header__desktop-menu').css('max-height', `${sizeActual - sizeButton - sizeControls}px`);
                $('.d-o-header__collapse').css('max-height',`${sizeActual}px`);
            } else {
                $(".d-o-header__collapse-content").css('height', 'calc(100vh - 67px - 77px)');
                $('.d-o-header__collapse').css('max-height','unset');
                $('.d-o-header__desktop-menu').css('max-height', `unset`);
            }
        }
        maxHeightContainerMobile();
        resizeComponent(maxHeightContainerMobile)
    }
    //Abrir y cerrar el menu amburguesa
    function burgerMenu(idBurger) {
        let collapse = `#${$(idBurger).attr('aria-controls')}`
        function toggleMenu(classOpen) {
            if(!$(collapse).hasClass(classOpen)) {
                $(idBurger).attr('aria-expanded', 'true');
                $(collapse).addClass(classOpen);
                $("body").addClass("not-scroll");
                closeSearch();
            } else {
                $(idBurger).attr('aria-expanded', 'false');
                $(collapse).removeClass(classOpen);
                $("body").removeClass("not-scroll");
            }
        }
        $(idBurger).click(function(){
            toggleMenu('d-t-header__collapse--open');
            setTimeout(function() {
                $(".d-t-dropdown__content").removeClass("hiddeTabPreheader");
            }, 300); // 2000 milisegundos = 2 segundos
        });
        $('#d-js-header__collapse--close').click(function(){
            toggleMenu('d-t-header__collapse--open');
            $(".d-t-dropdown__content").addClass("hiddeTabPreheader");


           

            
        });
    }
    //Se encarga de abrir un dropdown
    function openMenu($menu, openClass, closeClass) {
        $menu.removeClass(closeClass).addClass(openClass);
        $menu.css('display', 'block');
    }
    //se encarga de cerrar un dropdown
    function closeMenu($menu, openClass, closeClass) {
        let myBtn = $menu.parents('.d-o-dropdown').find('.d-t-header__lvl1')
        $menu.removeClass(openClass).addClass(closeClass);
        $menu.css('display', 'none');
        $menu.removeClass(closeClass);
    }
    function closeMenuAnimation($menu, openClass, closeClass) {
        $menu.removeClass(openClass).addClass(closeClass);
        setTimeout(function () {
            $menu.css('display', 'none');
            $menu.removeClass(closeClass);
        }, 550);
    }
    //Se encarga de abrir o cerrar un dropdown
    function toggleMenu($button, $menu, openClass, closeClass, withAnimation) {
        var isExpanded = $button.attr('aria-expanded') === 'true';
        $button.attr('aria-expanded', !isExpanded);
        if (isExpanded) {
            if(withAnimation) {
                closeMenuAnimation($menu, openClass, closeClass);
            }else {
                closeMenu($menu, openClass, closeClass);
            }
            
        } else {
            openMenu($menu, openClass, closeClass);
        }
    }
