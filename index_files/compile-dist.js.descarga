            */

        e.preventDefault();
        e.stopPropagation();
         // Define $this dentro del bloque de la función para asegurarse de que está bien definido
         let $this = $(this);
        // Lógica para 'keydown' y 'mouseenter'
        if ((e.type === 'keydown' && (e.key === 'Enter' || e.keyCode === 32)) ) {  

            
            function closeSearch() {
                // Aquí puedes agregar el código que cierre el buscador.
                // Ejemplo: ocultar el contenedor del buscador
                $(".d-o-header__tablet-search").fadeOut();  // O usa .hide() o .fadeOut() según el comportamiento que desees
            }

            let isDropdownOpen = $this.attr("aria-expanded") === "true"; // Verifica si el dropdown está abierto
            //removeDataPreHeader();
            let $content = $this.siblings(`.${objectJS}__content`); 
            $content.stop(true, true).slideUp(100).addClass('expand').addClass('rebounce');

            if (isDropdownOpen === false) {
                closeSearch(); // Cierra el buscador
            }

        // Si el dropdown está abierto, simula un clic para cerrarlo        
        if (isDropdownOpen && (e.type === 'keydown' && (e.key === 'Enter' || e.keyCode === 32))) {
            
            // Cierra el dropdown de forma explícita
            //$content.stop(true, true).slideUp(100).removeClass('expand').removeClass('rebounce');
            console.log("cerrando con enter")

            let $dropdown= (".d-t-dropdown__content");

            setTimeout(() => {
                $dropdown.css('--menuPreheader-height', '0px');
            }, 600);
            
            closeTimeout = setTimeout(() => {                
                dropdownOpen = false;
                $content.stop(true, true).slideUp(600).removeClass('expand').addClass('rebounce');
                $content.removeClass("d-t-dropdown__content-animation");
                $content.addClass("d-t-dropdown__content-animationRever");
                $(this).find('.d-t-dropdown__btn').attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
        
        }, 300);


            $this.attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
            return; // Salimos para no hacer más acciones si el dropdown se cierra          
        }
        
        //comenzamos la validacion si estabamos en otro dropdpwn para aplicar la animacion correspondiente
            if (!keyboardOpened) {
                clearTimeout(closeTimeout);
                // Obtén el botón y el contenido del dropdown actual
                let $this = $(this);
                let $content = $this.siblings(`.${objectJS}__content`);
                $content.removeClass("d-t-dropdown__content-animation-opacity");
                $(".d-t-dropdown__btn-preheader").siblings(`.${objectJS}__content`).removeClass("d-t-dropdown__content-animation-opacity");
                $(".d-t-dropdown__btn-preheader").siblings(`.${objectJS}__content`).removeClass("d-t-dropdown__content-animation");
                // Selecciona todos los dropdowns dentro del mismo contenedor de lista
                let $allDrops = $(".d-t-dropdown__btn");
                // Cierra todos los otros dropdowns
                $allDrops.not($this).each(function () {               
                    let $otherDropdown = $(this);
                    if ($otherDropdown.attr("aria-expanded") === "true") {
                        let otherContent = $otherDropdown.siblings(`.${objectJS}__content`);
                        otherContent.stop(true, true).slideUp(100).removeClass('expand').addClass('rebounce');
                        $otherDropdown.attr("aria-expanded", "false").removeClass(`${window.prefixClass.js}--active`);
                    }
                });

                if (mouseOverDropdown) {
                    // Añade animación de opacidad si el ratón está sobre el dropdown
                    $content.addClass("d-t-dropdown__content-animation-opacity");
                    $content.find(".d-t-dropdown__content-container").addClass("d-t-dropdown__content-container-opacity");
                    //$content.find(".d-t-dropdown__item-content").addClass("d-t-dropdown__item-content-opacity");
                    $content.removeClass("d-t-dropdown__content-animation-opacity-rever");                   
                    $content.removeClass("d-t-dropdown__content-animationRever");                   
                    $this.attr("aria-expanded", "true").addClass(`${window.prefixClass.js}--active`);
                    adjustContentPosition($content);
                    if (e.type === 'mouseenter') {
                        $(this).closest(".has-dropdown-btn").addClass('fondo-white-preheaderLi');
                    }

                } else {                   
                    // Si el ratón no está sobre el dropdown, se maneja la animación normal de abrir
                    $content.stop(true, true).slideDown(600).removeClass('rebounce').addClass('expand');
                    $content.addClass("d-t-dropdown__content-animation");
                    $content.removeClass("d-t-dropdown__content-animationRever");
                    $content.removeClass("d-t-dropdown__content-animation-opacity");
                    $this.attr("aria-expanded", "true").addClass(`${window.prefixClass.js}--active`);
                    // Actualiza el estado del dropdown anterior
                    previousDropdownVisible = $content.is(':visible');
                    adjustContentPosition($content);
                    //console.log("No estaba en un drop");
                    if (e.type === 'mouseenter') {
                        $(this).closest(".has-dropdown-btn").addClass('fondo-white-preheaderLi');
                    }
                }
            }
        }
    });

